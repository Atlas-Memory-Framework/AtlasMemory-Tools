# Copy to config.env and fill local-only values.

AGENT_REPO="OWNER/REPO"
AGENT_BASE_BRANCH="main"

AGENT_READY_LABEL="agent:ready"
AGENT_RUNNING_LABEL="agent:running"
AGENT_DONE_LABEL="agent:done"
AGENT_PR_OPEN_LABEL="agent:pr-open"
AGENT_FAILED_LABEL="agent:failed"
AGENT_ALLOW_WORKFLOWS_LABEL="agent:allow-workflows"
AGENT_ALLOW_INFRA_LABEL="agent:allow-infra"
AGENT_ALLOW_LARGE_LABEL="agent:allow-large"

AGENT_TRUSTED_AUTHORS="YOUR_GITHUB_LOGIN"
AGENT_GIT_USER_NAME="Local Automation Agent"
AGENT_GIT_USER_EMAIL="local-automation-agent@users.noreply.github.com"

AGENT_HOME="$PWD"
AGENT_REPOS="$PWD/repos"
AGENT_JOBS="$PWD/jobs"
AGENT_LOGS="$PWD/logs"
AGENT_CODEX_HOME="$PWD/codex-home"

AGENT_MAX_FILES_CHANGED="20"
AGENT_MAX_DIFF_LINES="1200"
AGENT_CODEX_TIMEOUT_SECONDS="1800"

AGENT_CODEX_IMAGE="localhost/codex-agent:latest"
AGENT_PODMAN_CMD="podman"

# Optional per-stage Codex profiles. Prefer profiles for full model/reasoning
# configuration; use *_MODEL or *_EXTRA_ARGS for small local overrides.
AGENT_CODEX_PLANNING_PROFILE=""
AGENT_CODEX_IMPLEMENTATION_PROFILE=""
AGENT_CODEX_TESTING_PROFILE=""
AGENT_CODEX_REVIEW_PROFILE=""
AGENT_CODEX_REPAIR_PROFILE=""
AGENT_CODEX_PLANNING_MODEL=""
AGENT_CODEX_IMPLEMENTATION_MODEL=""
AGENT_CODEX_REVIEW_MODEL=""
AGENT_CODEX_REPAIR_MODEL=""
AGENT_CODEX_PLANNING_EXTRA_ARGS=""
AGENT_CODEX_IMPLEMENTATION_EXTRA_ARGS=""
AGENT_CODEX_REVIEW_EXTRA_ARGS=""
AGENT_CODEX_REPAIR_EXTRA_ARGS=""

TEAMS_ISSUES_WEBHOOK_URL=""
TEAMS_URGENT_WEBHOOK_URL=""
TEAMS_DAILY_DIGEST_WEBHOOK_URL=""
TEAMS_WEBHOOK_URL=""
