def run(cmd, cwd=None, check=True, capture=True, env=None):
    print(f"+ {cmd}", flush=True)
    if cmd.strip().startswith("git "):
        env = common.git_env(env)
    gh_parts = common.github_throttle_shell_command(cmd)
    p = subprocess.run(
        cmd,
        cwd=cwd,
        shell=True,
        text=True,
        stdout=subprocess.PIPE if capture else None,
        stderr=subprocess.STDOUT if capture else None,
        env=env,
    )
    common.github_throttle_after(gh_parts, p.stdout or "", p.returncode)
    if check and p.returncode != 0:
        raise RuntimeError(f"Command failed: {cmd}\n{p.stdout or ''}")
    return p.stdout or ""


def codex_timeout_seconds():
    try:
        return max(int(os.environ.get("AGENT_CODEX_TIMEOUT_SECONDS", "1800")), 1)
    except ValueError:
        return 1800


def with_timeout(cmd):
    if shutil.which("timeout"):
        return f"timeout {codex_timeout_seconds()} {cmd}"
    return cmd


def run_codex(codex_cmd, local_cmd, cwd, run_home):
    codex_log = run(with_timeout(codex_cmd), cwd=cwd, check=False)
    if "podman: command not found" not in codex_log.lower():
        return codex_log
    if not shutil.which("codex"):
        return codex_log + "\nlocal codex fallback is unavailable\n"
    env = os.environ.copy()
    env["CODEX_HOME"] = str(run_home)
    return run(with_timeout(local_cmd), cwd=cwd, check=False, env=env)


def gh_json(cmd):
    out = run(cmd)
    return json.loads(out) if out.strip() else None


def now_id():
    return datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")


def require_env(name):
    val = os.environ.get(name)
    if not val:
        raise SystemExit(f"Missing env var: {name}")
    return val


def env_int(name, default):
    try:
        return int(os.environ.get(name, default))
    except ValueError:
        raise SystemExit(f"{name} must be an integer")


def label_names(issue):
    return {label["name"] for label in issue.get("labels", [])}


def trusted_author(issue):
    trusted = {
        item.strip()
        for item in os.environ.get("AGENT_TRUSTED_AUTHORS", "").split(",")
        if item.strip()
    }
    if not trusted:
        return False
    author = (issue.get("author") or {}).get("login")
    return author in trusted


def issue_is_ready(issue):
    labels = label_names(issue)
    return (
        os.environ["AGENT_READY_LABEL"] in labels
        and os.environ["AGENT_RUNNING_LABEL"] not in labels
        and trusted_author(issue)
    )


def safe_branch(issue_number, job_id):
    return f"agent/issue-{issue_number}/{job_id}"


def quote_path(path):
    return shlex.quote(str(path))


def acquire_file_lock(path, stale_seconds=3600, wait_seconds=300):
    path.parent.mkdir(parents=True, exist_ok=True)
    deadline = time.time() + wait_seconds
    while True:
        if path.exists() and time.time() - path.stat().st_mtime > stale_seconds:
            path.unlink(missing_ok=True)
        try:
            fd = os.open(path, os.O_CREAT | os.O_EXCL | os.O_WRONLY, 0o644)
        except FileExistsError:
            if time.time() >= deadline:
                raise RuntimeError(f"Timed out waiting for lock: {path}")
            time.sleep(2)
            continue
        with os.fdopen(fd, "w", encoding="utf-8") as handle:
            handle.write(json.dumps({"pid": os.getpid(), "created_at": now_id()}) + "\n")
        return path


def release_file_lock(path):
    if path:
        path.unlink(missing_ok=True)


def podman_command():
    configured = os.environ.get("AGENT_PODMAN_CMD", "").strip()
    return configured or "podman"


def podman_userns_segment():
    parts = shlex.split(podman_command())
    return "" if parts and parts[0] == "sudo" else "--userns=keep-id "


def disable_repo_hooks():
    return os.environ.get("AGENT_DISABLE_REPO_HOOKS", "1").strip().lower() not in {"0", "false", "no"}


def tools_mount_paths():
    configured = os.environ.get("AGENT_TOOLS_MOUNT_PATHS", "").strip()
    if configured:
        candidates = [pathlib.Path(item.strip()).expanduser() for item in configured.split(",") if item.strip()]
    else:
        candidates = [
            pathlib.Path("/var/home/mat/Desktop/AtlasMemory-Tools"),
            pathlib.Path("/run/host/var/home/mat/Desktop/AtlasMemory-Tools"),
        ]
    return [path for path in candidates if path.exists()]


def worker_container_volumes(run_home, worktree_dir, job_dir, repo_dir):
    volumes = [
        f"-v {quote_path(run_home)}:/home/agent/.codex:Z",
        f"-v {quote_path(worktree_dir)}:/work:Z",
        f"-v {quote_path(job_dir)}:/job:Z",
        # Git worktrees use a .git file that points back into the cached clone.
        # Mount the cache at the same absolute path so git commands work inside /work.
        f"-v {quote_path(repo_dir)}:{quote_path(repo_dir)}:Z",
    ]
    for path in tools_mount_paths():
        # Issue validation commands can reference the Tools checkout by host path.
        # Keep this read-only; workers should not edit the SSOT tooling repo.
        volumes.append(f"-v {quote_path(path)}:{quote_path(path)}:ro,Z")
    return " ".join(volumes)


def changed_paths(repo_dir):
    rows = run("git diff --cached --name-status --diff-filter=ACDMRTUXB", cwd=repo_dir).splitlines()
    paths = []
    statuses = []
    for row in rows:
        parts = row.split("\t")
        if not parts:
            continue
        statuses.append(parts[0])
        if parts[0].startswith("R") and len(parts) >= 3:
            paths.append(parts[2])
        elif len(parts) >= 2:
            paths.append(parts[1])
    return paths, statuses


def executable_paths(repo_dir):
    out = run("git diff --cached --summary", cwd=repo_dir)
    paths = []
    for line in out.splitlines():
        marker = "create mode 100755 "
        if marker in line:
            paths.append(line.split(marker, 1)[1].strip())
    return paths


def blocked_policy_violations(paths, labels):
    return [f"{item['path']} requires {item['label']}" for item in blocked_policy_requirements(paths, labels)]


def blocked_policy_requirements(paths, labels):
    workflow_patterns = [
        ".github/workflows/**",
        ".github/actions/**",
    ]
    infra_patterns = [
        "**/*secret*",
        "**/*token*",
        ".env*",
        "deploy/**",
        "infra/**",
        "terraform/**",
    ]

    requirements = []
    allow_workflows = os.environ["AGENT_ALLOW_WORKFLOWS_LABEL"] in labels
    allow_infra = os.environ["AGENT_ALLOW_INFRA_LABEL"] in labels

    for path in paths:
        if not allow_workflows and any(fnmatch.fnmatch(path, pat) for pat in workflow_patterns):
            requirements.append({"path": path, "label": os.environ["AGENT_ALLOW_WORKFLOWS_LABEL"]})
        if not allow_infra and any(fnmatch.fnmatch(path, pat) for pat in infra_patterns):
            requirements.append({"path": path, "label": os.environ["AGENT_ALLOW_INFRA_LABEL"]})
    return requirements


def changed_file_records(paths, statuses):
    records = []
    for index, path in enumerate(paths):
        records.append({"path": path, "status": statuses[index] if index < len(statuses) else ""})
    return records


def write_policy_gate_record(
    job_dir,
    issue,
    repo,
    job_id,
    base_sha,
    paths,
    statuses,
    required_labels,
    diff_stat,
    diff_lines,
    policy_errors,
):
    record = {
        "issue": {
            "number": issue.get("number"),
            "title": issue.get("title"),
            "url": issue.get("url"),
            "labels": sorted(label_names(issue)),
        },
        "repo": repo,
        "job_id": job_id,
        "base_sha": base_sha,
        "changed_files": changed_file_records(paths, statuses),
        "required_labels": sorted(set(required_labels)),
        "diff_stats": {
            "stat": diff_stat,
            "line_count": diff_lines,
            "file_count": len(paths),
        },
        "policy_errors": policy_errors,
        "next_action": "Add the required approval labels, then requeue the issue. The worker will rerun from scratch.",
    }
    (job_dir / "policy-gate.json").write_text(json.dumps(record, indent=2) + "\n", encoding="utf-8")
    return record


