#!/usr/bin/env python3
"""Add a validated local Atlas workflow template JSON file."""

from __future__ import annotations

import argparse
import json
import pathlib
import sys
from typing import Any


RUNTIME_DIR = pathlib.Path(__file__).resolve().parent
if str(RUNTIME_DIR) not in sys.path:
    sys.path.insert(0, str(RUNTIME_DIR))

import atlas_workflows


def parse_role_json(values: list[str]) -> list[dict[str, Any]]:
    roles: list[dict[str, Any]] = []
    for value in values:
        try:
            role = json.loads(value)
        except json.JSONDecodeError as exc:
            raise ValueError(f"invalid --role-json: {exc}") from exc
        if not isinstance(role, dict):
            raise ValueError("--role-json must decode to an object")
        roles.append(role)
    return roles


def template_path(target: str | pathlib.Path, template_id: str) -> pathlib.Path:
    path = pathlib.Path(target)
    if path.suffix == ".json":
        return path
    return path / f"{template_id}.json"


def build_template_payload(args: argparse.Namespace) -> dict[str, Any]:
    return {
        "id": args.template_id,
        "name": args.name or args.template_id,
        "purpose": args.purpose or "",
        "workflow_kind": args.workflow_kind,
        "roles": parse_role_json(args.role_json or []),
        "rollup": {
            "missing_outputs_block_completion": not args.allow_partial_rollup,
            "require_coverage": not args.allow_partial_rollup,
        },
    }


def add_template(
    target: str | pathlib.Path,
    payload: dict[str, Any],
    *,
    force: bool = False,
) -> pathlib.Path:
    template = atlas_workflows.TeamTemplate.from_dict(payload)
    errors = template.validate()
    if errors:
        raise ValueError("template validation failed: " + "; ".join(errors))
    path = template_path(target, template.id)
    if path.exists() and not force:
        raise ValueError(f"workflow template already exists: {path}")
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(template.to_dict(), indent=2) + "\n", encoding="utf-8")
    return path


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("target", help="Template JSON output file or directory.")
    parser.add_argument("--id", required=True, dest="template_id", help="Workflow template id.")
    parser.add_argument("--name", default="")
    parser.add_argument("--purpose", default="")
    parser.add_argument("--workflow-kind", required=True)
    parser.add_argument(
        "--role-json",
        action="append",
        default=[],
        help=(
            "Role JSON object with id, agent_ref, must_produce, optional consumes/skills/acceptance_criteria. "
            "Provide once per role."
        ),
    )
    parser.add_argument(
        "--allow-partial-rollup",
        action="store_true",
        help="Do not require final rollup coverage of all prior roles.",
    )
    parser.add_argument("--force", action="store_true", help="Overwrite an existing template file.")
    parser.add_argument("--json", action="store_true")
    return parser


def main(argv: list[str] | None = None) -> int:
    args = build_parser().parse_args(argv)
    try:
        payload = build_template_payload(args)
        path = add_template(args.target, payload, force=args.force)
    except ValueError as exc:
        print(str(exc), file=sys.stderr)
        return 1
    if args.json:
        print(json.dumps({"template": payload, "path": str(path)}, indent=2, sort_keys=True))
    else:
        print(f"Added workflow template {payload['id']} at {path}.")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
