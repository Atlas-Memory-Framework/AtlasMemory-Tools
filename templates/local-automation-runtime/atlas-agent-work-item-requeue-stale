#!/usr/bin/env python3
"""Preview or requeue stale running local Atlas work items."""

from __future__ import annotations

import argparse
import json
import pathlib
import sys


RUNTIME_DIR = pathlib.Path(__file__).resolve().parent
if str(RUNTIME_DIR) not in sys.path:
    sys.path.insert(0, str(RUNTIME_DIR))

import atlas_work_items


def requeue_stale(
    store_path: str | pathlib.Path,
    *,
    stale_seconds: float,
    actor: str,
    apply: bool,
) -> list[dict]:
    provider = atlas_work_items.AtlasWorkItemOperationProvider(
        atlas_work_items.AtlasWorkItemStore(store_path),
        claimed_by=actor,
    )
    return provider.requeue_stale_claims(
        stale_seconds=stale_seconds,
        requeued_by=actor,
        apply=apply,
    )


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("store", help="Path to a local Atlas work-item JSON store.")
    parser.add_argument("--stale-seconds", type=float, default=6 * 60 * 60)
    parser.add_argument("--actor", default="atlas-agent-work-item-requeue-stale")
    parser.add_argument("--apply", action="store_true", help="Mutate the store. Omit to preview stale claims.")
    parser.add_argument("--json", action="store_true")
    return parser


def main(argv: list[str] | None = None) -> int:
    args = build_parser().parse_args(argv)
    records = requeue_stale(
        args.store,
        stale_seconds=args.stale_seconds,
        actor=args.actor,
        apply=args.apply,
    )
    if args.json:
        print(json.dumps({"applied": bool(args.apply), "records": records}, indent=2, sort_keys=True))
        return 0
    action = "Requeued" if args.apply else "Would requeue"
    print(f"{action} {len(records)} stale local Atlas work item(s).")
    for record in records:
        print(
            f"- {record['source_id']}: age={record['age_seconds']}s "
            f"threshold={record['stale_seconds']}s previous={record['previous_state']}"
        )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
