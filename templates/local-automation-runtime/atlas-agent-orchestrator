def has_open_pr_for_issue(repo: str, number: int) -> bool:
    prs = common.gh_json_or_none(
        [
            "pr",
            "list",
            "--repo",
            repo,
            "--state",
            "open",
            "--search",
            f"#{number}",
            "--json",
            "number,title,url,state,isDraft",
        ],
        retries=2,
    )
    return bool(prs)


def execution_repo_for_issue(source_repo: str, issue: dict) -> str:
    return common.issue_body_execution_repo(issue) or source_repo


def issue_points(issue: dict) -> int | None:
    return common.issue_points(issue)


def point_gate_reasons(issue: dict, *, require_one_point: bool) -> list[str]:
    return common.issue_point_blockers(issue, require_one_point=require_one_point)


def hard_non_execution_reasons(issue: dict, *, require_one_point: bool = False) -> list[str]:
    labels = common.label_names(issue)
    body = issue.get("body") or ""
    title = issue.get("title") or ""
    reasons: list[str] = []
    blocked_labels = sorted(labels & HARD_NON_EXECUTION_LABELS)
    if blocked_labels:
        reasons.append(f"labels {blocked_labels}")
    if any(title.startswith(prefix) for prefix in NON_EXECUTION_TITLE_PREFIXES):
        reasons.append("tracker/epic title")
    lowered = body.lower()
    if "dispatch recommendation: `tracking-only`" in lowered:
        reasons.append("tracking-only dispatch recommendation")
    if (
        "dispatch recommendation: `review-before-dispatch`" in lowered
        and "agent:approved-dispatch" not in labels
    ):
        reasons.append("review-before-dispatch requires explicit queueing")
    reasons.extend(
        common.issue_execution_metadata_blockers(
            issue,
            require_one_point=require_one_point,
        )
    )
    return reasons


def failed_inspection_hard_reasons(issue: dict, *, require_one_point: bool = False) -> list[str]:
    reasons = hard_non_execution_reasons(issue, require_one_point=require_one_point)
    labels = common.label_names(issue)
    if "needs-human" in labels and not reasons:
        return []
    return reasons


def recommended_policy_allow_labels(issue: dict) -> set[str]:
    body = str(issue.get("body") or "").lower()
    labels = common.label_names(issue)
    tokens = set(labels)
    for token in ("infra", "ci-cd", "auth", "needs-deployed-validation", "cross-repo", "tier:t4+", "t5"):
        if token in body:
            tokens.add(token)
    wanted: set[str] = set()
    if {"infra", "auth", "needs-deployed-validation"} & tokens:
        wanted.add("agent:allow-infra")
    if {"ci-cd", "needs-deployed-validation"} & tokens:
        wanted.add("agent:allow-workflows")
    if {"tier:t4+", "t5"} & tokens:
        wanted.add("agent:allow-large")
    return wanted


def dispatch_blockers(repo: str, issue: dict, args: argparse.Namespace, *, check_open_pr: bool) -> list[str]:
    labels = common.label_names(issue)
    author = (issue.get("author") or {}).get("login")
    reasons = hard_non_execution_reasons(
        issue,
        require_one_point=bool(getattr(args, "require_one_point", False)),
    )
    if author not in common.trusted_authors():
        reasons.append(f"untrusted author {author}")
    missing_allow = sorted(recommended_policy_allow_labels(issue) - labels)
    if missing_allow:
        reasons.append("missing policy allow label(s): " + ", ".join(missing_allow))
    execution_repo = execution_repo_for_issue(repo, issue)
    if check_open_pr and has_open_pr_for_issue(execution_repo, issue["number"]):
        reasons.append("open PR appears linked")
    if "agent:running" in labels:
        reasons.append("agent:running label")
    return reasons


def dispatch_preview_record(repo: str, issue: dict, reasons: list[str]) -> dict:
    return {
        "repo": repo,
        "number": int(issue["number"]),
        "title": issue.get("title") or "",
        "url": issue.get("url") or "",
        "labels": sorted(common.label_names(issue)),
        "reasons": reasons,
    }


def write_dispatch_preview(summary_path: str | None, preview: dict) -> None:
    if not summary_path:
        return
    path = Path(summary_path)
    payload: dict = {}
    if path.exists():
        try:
            payload = json.loads(path.read_text(encoding="utf-8"))
        except json.JSONDecodeError:
            payload = {}
    payload["dispatch_preview"] = preview
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(payload, indent=2) + "\n", encoding="utf-8")


def print_dispatch_preview(preview: dict) -> None:
    runnable = preview.get("next_runnable") or []
    blocked = preview.get("blocked") or []
    print(
        f"Dispatch preview: {len(runnable)} runnable, {len(blocked)} blocked before dispatch.",
        flush=True,
    )
    for item in runnable[:5]:
        print(f"RUNNABLE {item['repo']}#{item['number']}: {item['title']}", flush=True)
    for item in blocked[:8]:
        print(
            f"BLOCKED {item['repo']}#{item['number']}: {', '.join(item.get('reasons') or [])}",
            flush=True,
        )


def maybe_queue_issue(repo: str, issue: dict, args: argparse.Namespace) -> bool:
    labels = common.label_names(issue)
    blocked = {
        "agent:ready",
        "agent:running",
        "agent:done",
        "agent:pr-open",
        "agent:failed",
    }
    reasons = hard_non_execution_reasons(
        issue,
        require_one_point=bool(getattr(args, "require_one_point", False)),
    )
    if labels & blocked or reasons:
        if reasons:
            print(f"Not queueing {repo}#{issue['number']}: {', '.join(reasons)}.", flush=True)
        return False
    author = (issue.get("author") or {}).get("login")
    if author not in common.trusted_authors():
        print(f"Not queueing {repo}#{issue['number']}: untrusted author {author}.", flush=True)
        return False
    if args.auto_queue_skip_open_pr and has_open_pr_for_issue(execution_repo_for_issue(repo, issue), issue["number"]):
        print(f"Not queueing {repo}#{issue['number']}: open PR appears linked.", flush=True)
        return False
    if getattr(args, "dry_run", False):
        print(f"DRY-RUN queue {repo}#{issue['number']} from {args.auto_queue_label}: {issue['title']}", flush=True)
        return False
    print(f"Queueing {repo}#{issue['number']} from {args.auto_queue_label}: {issue['title']}", flush=True)
    common.run(["gh", "issue", "edit", str(issue["number"]), "--repo", repo, "--add-label", "agent:ready"], retries=3)
    common.update_issue_automation_state(repo, int(issue["number"]), "Queued")
    return True


def run_worker(
    issue_repo: str,
    execution_repo: str,
    number: int,
    publish: bool,
    base_branch: str | None = None,
) -> int:
    env = common.env_for_repo(execution_repo, base_branch=base_branch)
    env["AGENT_ISSUE_REPO"] = issue_repo
    common.ensure_git_identity(common.ensure_repo(execution_repo))
    cmd = [str(common.local_worker()), "--once", "--issue", str(number)]
    if publish:
        cmd.append("--publish")
    proc = subprocess.run(cmd, cwd=str(common.RUNTIME_DIR), env=env)
    return proc.returncode


def issue_lease_path(repo: str, number: int) -> Path:
    safe_repo = repo.replace("/", "__")
    return common.jobs_dir() / "leases" / f"{safe_repo}__issue-{number}.lock"


def acquire_issue_lease(repo: str, issue: dict, stale_seconds: int) -> Path | None:
    path = issue_lease_path(repo, int(issue["number"]))
    path.parent.mkdir(parents=True, exist_ok=True)
    now = time.time()
    if path.exists() and stale_seconds > 0:
        age = now - path.stat().st_mtime
        if age > stale_seconds:
            print(f"Removing stale lease for {repo}#{issue['number']} ({age:.0f}s old).", flush=True)
            path.unlink(missing_ok=True)
    payload = {
        "repo": repo,
        "issue": int(issue["number"]),
        "pid": os.getpid(),
        "created_at": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
    }
    try:
        fd = os.open(path, os.O_CREAT | os.O_EXCL | os.O_WRONLY, 0o644)
    except FileExistsError:
        print(f"Skipping {repo}#{issue['number']}: issue lease already exists at {path}.", flush=True)
        return None
    with os.fdopen(fd, "w", encoding="utf-8") as handle:
        json.dump(payload, handle, indent=2)
        handle.write("\n")
    return path


def release_issue_lease(path: Path | None) -> None:
    if path is not None:
        path.unlink(missing_ok=True)


def dispatch_base_branch(repo: str, issue: dict) -> str:
    body_base = common.issue_body_base_branch(issue)
    if body_base:
        return body_base
    cfg = common.read_config()
    env_key = "AGENT_BASE_BRANCH_" + re.sub(r"[^A-Za-z0-9]+", "_", repo).strip("_").upper()
    return os.environ.get(env_key) or cfg.get(env_key) or os.environ.get("AGENT_BASE_BRANCH") or cfg.get("AGENT_BASE_BRANCH") or "default"


def issue_write_scope(issue: dict) -> list[str]:
    body = str(issue.get("body") or "")
    values: list[str] = []
    values.extend(common.markdown_section_items(body, "Write Scope"))
    values.extend(common.body_field_values(body, "WriteScope"))
    values.extend(common.body_field_values(body, "Write Scope"))
    values.extend(common.body_field_values(body, "Files in scope"))
    values.extend(common.body_field_values(body, "Owns files"))

    scopes: list[str] = []
    seen: set[str] = set()
    for raw in values:
        for value in re.split(r"[\n,]", str(raw)):
            scope = normalize_scope(value)
            if not scope or scope.lower() in common.NONE_FIELD_VALUES or scope in seen:
                continue
            seen.add(scope)
            scopes.append(scope)
    return scopes


def normalize_scope(value: str) -> str:
    scope = str(value).strip().strip("`").strip()
    scope = re.sub(r"^\s*[-*]\s*", "", scope).strip().strip("`").strip()
    if scope.startswith("./"):
        scope = scope[2:]
    return scope.rstrip("/")


def scope_is_unknown(scope: str) -> bool:
    lowered = scope.lower().strip()
    if lowered in common.NONE_FIELD_VALUES:
        return True
    unknown_markers = (
        "unknown",
        "tbd",
        "to be determined",
        "entire repo",
        "whole repo",
        "repo-wide",
        "repository-wide",
        "all files",
        "*",
    )
    return any(marker == lowered or marker in lowered for marker in unknown_markers)


def write_scope_lock_dir(repo: str, base_branch: str) -> Path:
    safe_repo = repo.replace("/", "__")
    base_key = hashlib.sha256(base_branch.encode("utf-8")).hexdigest()[:16]
    return common.jobs_dir() / "write-scope-locks" / safe_repo / base_key


def lock_payload(repo: str, issue: dict, base_branch: str, scopes: list[str], exclusive: bool) -> dict:
    return {
        "repo": repo,
        "issue": int(issue["number"]),
        "base_branch": base_branch,
        "scopes": scopes,
        "exclusive": exclusive,
        "pid": os.getpid(),
        "created_at": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
    }


def acquire_raw_lock(path: Path, payload: dict, stale_seconds: int) -> bool:
    path.parent.mkdir(parents=True, exist_ok=True)
    if path.exists() and stale_seconds > 0:
        age = time.time() - path.stat().st_mtime
        if age > stale_seconds:
            print(f"Removing stale lock {path} ({age:.0f}s old).", flush=True)
            path.unlink(missing_ok=True)
    try:
        fd = os.open(path, os.O_CREAT | os.O_EXCL | os.O_WRONLY, 0o644)
    except FileExistsError:
        return False
    with os.fdopen(fd, "w", encoding="utf-8") as handle:
        json.dump(payload, handle, indent=2)
        handle.write("\n")
    return True


def acquire_namespace_lock(lock_dir: Path, stale_seconds: int) -> Path | None:
    path = lock_dir / "_namespace.lock"
    payload = {"pid": os.getpid(), "created_at": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")}
    deadline = time.time() + 10
    while time.time() < deadline:
        if acquire_raw_lock(path, payload, stale_seconds):
            return path
        time.sleep(0.2)
    return None


def read_scope_lock(path: Path, stale_seconds: int) -> dict | None:
    if path.name == "_namespace.lock":
        return None
    if stale_seconds > 0 and path.exists():
        age = time.time() - path.stat().st_mtime
        if age > stale_seconds:
            print(f"Removing stale write-scope lock {path} ({age:.0f}s old).", flush=True)
            path.unlink(missing_ok=True)
            return None
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except (FileNotFoundError, json.JSONDecodeError):
        path.unlink(missing_ok=True)
        return None
    return payload if isinstance(payload, dict) else None


def migration_or_schema_scope(scope: str) -> bool:
    segments = [segment.lower() for segment in scope.split("/") if segment]
    return any("migration" in segment or "schema" in segment for segment in segments)


def same_parent_dir(a: str, b: str) -> bool:
    parent_a = a.rsplit("/", 1)[0] if "/" in a else ""
    parent_b = b.rsplit("/", 1)[0] if "/" in b else ""
    return parent_a == parent_b


def scopes_overlap(a: str, b: str) -> bool:
    left = normalize_scope(a)
    right = normalize_scope(b)
    if not left or not right:
        return True
    if scope_is_unknown(left) or scope_is_unknown(right):
        return True
    if "*" in left or "*" in right:
        return True
    if left == right:
        return True
    if left.startswith(right + "/") or right.startswith(left + "/"):
        return True
    if migration_or_schema_scope(left) and migration_or_schema_scope(right) and same_parent_dir(left, right):
        return True
    return False


def active_scope_locks(lock_dir: Path, stale_seconds: int) -> list[tuple[Path, dict]]:
    locks: list[tuple[Path, dict]] = []
    for path in sorted(lock_dir.glob("*.lock")):
        payload = read_scope_lock(path, stale_seconds)
        if payload:
            locks.append((path, payload))
    return locks


def acquire_write_scope_lease(
    repo: str,
    issue: dict,
    base_branch: str,
    stale_seconds: int,
) -> tuple[list[Path], str | None]:
    lock_dir = write_scope_lock_dir(repo, base_branch)
    namespace = acquire_namespace_lock(lock_dir, stale_seconds)
    if namespace is None:
        return [], "write-scope lock namespace is busy"

    acquired: list[Path] = []
    scopes = issue_write_scope(issue)
    exclusive = not scopes or any(scope_is_unknown(scope) for scope in scopes)
    try:
        existing = active_scope_locks(lock_dir, stale_seconds)
        if exclusive and existing:
            owners = ", ".join(f"#{payload.get('issue', '?')}" for _path, payload in existing[:5])
            return [], f"exclusive write scope waits for active lock(s): {owners}"
        for _path, payload in existing:
            if payload.get("exclusive"):
                return [], f"active exclusive write-scope lock for issue #{payload.get('issue', '?')}"
            existing_scopes = [str(scope) for scope in payload.get("scopes") or []]
            for scope in scopes:
                conflict = next((existing_scope for existing_scope in existing_scopes if scopes_overlap(scope, existing_scope)), None)
                if conflict is not None:
                    return [], (
                        f"write scope `{scope}` overlaps `{conflict}` "
                        f"from issue #{payload.get('issue', '?')}"
                    )

        payload = lock_payload(repo, issue, base_branch, scopes, exclusive)
        lock_names = ["exclusive"] if exclusive else [hashlib.sha256(scope.encode("utf-8")).hexdigest()[:24] for scope in scopes]
        for name in lock_names:
            path = lock_dir / f"{name}.lock"
            if not acquire_raw_lock(path, payload, stale_seconds):
                for acquired_path in acquired:
                    acquired_path.unlink(missing_ok=True)
                return [], f"write-scope lock appeared at {path}"
            acquired.append(path)
        return acquired, None
    finally:
        namespace.unlink(missing_ok=True)


def release_write_scope_lease(paths: list[Path]) -> None:
    for path in paths:
        path.unlink(missing_ok=True)


def latest_issue_job_dir(number: int) -> Path | None:
    candidates = sorted(common.jobs_dir().glob(f"issue-{number}-*"), reverse=True)
    return candidates[0] if candidates else None


def notification_state_path() -> Path:
    return common.jobs_dir() / "local-agent-notify-state.json"


def notification_digest(payload: dict) -> str:
    text = json.dumps(payload, sort_keys=True, separators=(",", ":"), ensure_ascii=True)
    return hashlib.sha256(text.encode("utf-8")).hexdigest()


def post_webhook(webhook: str, payload: dict) -> int:
    data = json.dumps(payload).encode("utf-8")
    req = request.Request(webhook, data=data, headers={"Content-Type": "application/json"}, method="POST")
    with request.urlopen(req, timeout=30) as response:
        return response.status


def build_worker_notification(
    *,
    repo: str,
    issue: dict,
    job_dir: Path | None,
    rc: int,
) -> tuple[str, dict] | None:
    cfg = common.read_config()
    success = rc == 0
    webhook = (
        os.environ.get("TEAMS_ISSUES_WEBHOOK_URL")
        or cfg.get("TEAMS_ISSUES_WEBHOOK_URL")
        if success
        else os.environ.get("TEAMS_URGENT_WEBHOOK_URL") or cfg.get("TEAMS_URGENT_WEBHOOK_URL")
    )
    if not webhook:
        return None
    number = issue["number"]
    title = issue.get("title") or f"{repo}#{number}"
    issue_url = issue.get("url") or f"https://github.com/{repo}/issues/{number}"
    job_name = job_dir.name if job_dir else "unknown-job"
    comment = ""
    if job_dir and (job_dir / "comment.md").exists():
        comment = (job_dir / "comment.md").read_text(encoding="utf-8", errors="replace")
    error = ""
    if job_dir and (job_dir / "error.txt").exists():
        error = (job_dir / "error.txt").read_text(encoding="utf-8", errors="replace")
    pr_url = ""
    if "PR: " in comment:
        pr_url = comment.split("PR: ", 1)[1].splitlines()[0].strip()

    status = "completed" if success else "failed"
    theme = "107C10" if success else "D13438"
    text_lines = [
        f"**Issue:** [{repo}#{number}]({issue_url})",
        f"**Job:** `{job_name}`",
    ]
    if pr_url:
        text_lines.append(f"**PR:** {pr_url}")
    if error:
        text_lines.append("**Error:**")
        text_lines.append(f"```text\n{error[:1800]}\n```")
    elif comment:
        text_lines.append(comment[:1800])

    payload = {
        "@type": "MessageCard",
        "@context": "https://schema.org/extensions",
        "themeColor": theme,
        "summary": f"Local automation agent {status}: {repo}#{number}",
        "title": f"Local automation agent {status}: {title}",
        "text": "\n\n".join(text_lines),
        "potentialAction": [
            {
                "@type": "OpenUri",
                "name": "Open issue",
                "targets": [{"os": "default", "uri": issue_url}],
            }
        ],
    }
    if pr_url:
        payload["potentialAction"].append(
            {
                "@type": "OpenUri",
                "name": "Open PR",
                "targets": [{"os": "default", "uri": pr_url}],
            }
        )
    key_payload = {
        "repo": repo,
        "issue": number,
        "status": status,
        "job": job_name,
        "pr_url": pr_url,
        "error": error[:500],
    }
    payload["dedupe_key"] = notification_digest(key_payload)
    return webhook, payload


def notify_worker_result(repo: str, issue: dict, rc: int) -> None:
    result = build_worker_notification(
        repo=repo,
        issue=issue,
        job_dir=latest_issue_job_dir(issue["number"]),
        rc=rc,
    )
    if not result:
        return
    webhook, payload = result
    state_path = notification_state_path()
    state: dict[str, object] = {}
    if state_path.exists():
        try:
            state = json.loads(state_path.read_text(encoding="utf-8"))
        except json.JSONDecodeError:
            state = {}
    sent = set(state.get("sent_worker_notifications") or [])
    dedupe_key = str(payload["dedupe_key"])
    if dedupe_key in sent:
        print(f"Teams worker notification already sent for {repo}#{issue['number']}.", flush=True)
        return
    try:
        status = post_webhook(webhook, payload)
    except Exception as exc:
        print(f"Teams worker notification failed for {repo}#{issue['number']}: {exc}", flush=True)
        return
    sent.add(dedupe_key)
    state["sent_worker_notifications"] = sorted(sent)[-500:]
    state["last_worker_notification_at"] = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    state["last_worker_notification"] = {
        "repo": repo,
        "issue": issue["number"],
        "dedupe_key": dedupe_key,
        "http_status": status,
    }
    state_path.parent.mkdir(parents=True, exist_ok=True)
    state_path.write_text(json.dumps(state, indent=2) + "\n", encoding="utf-8")
    print(f"Teams worker notification accepted for {repo}#{issue['number']} with HTTP {status}.", flush=True)


def admin_inspect(
    repo: str,
    number: int,
    auto_create_missing_base: bool = False,
    auto_allow_policy_labels: bool = False,
) -> int:
    issue_ref = f"{repo}#{number}"
    proc = subprocess.run(
        [str(common.RUNTIME_DIR / "atlas-agent-admin"), "inspect", issue_ref],
        cwd=str(common.RUNTIME_DIR),
    )
    if proc.returncode == 2 and auto_create_missing_base:
        subprocess.run(
            [str(common.RUNTIME_DIR / "atlas-agent-admin"), "create-base", issue_ref, "--requeue"],
            cwd=str(common.RUNTIME_DIR),
            check=False,
        )
    if proc.returncode == 2 and auto_allow_policy_labels:
        subprocess.run(
            [str(common.RUNTIME_DIR / "atlas-agent-admin"), "allow-policy", issue_ref, "--requeue"],
            cwd=str(common.RUNTIME_DIR),
            check=False,
        )
    return proc.returncode


def requeue_ready(repo: str, number: int) -> None:
    common.run(["gh", "issue", "edit", str(number), "--repo", repo, "--remove-label", "agent:done"], check=False)
    common.run(["gh", "issue", "edit", str(number), "--repo", repo, "--remove-label", "agent:pr-open"], check=False)
    common.run(["gh", "issue", "edit", str(number), "--repo", repo, "--remove-label", "agent:failed"], check=False)
    common.run(["gh", "issue", "edit", str(number), "--repo", repo, "--add-label", "agent:ready"], retries=3)


def maybe_dispatch_deploy_candidate(repo: str, issue: dict, args: argparse.Namespace) -> None:
    labels = common.label_names(issue)
    body = issue.get("body") or ""
    needs_deployed = "needs-deployed-validation" in body or "needs-deployed-validation" in labels
    if not needs_deployed or not args.dispatch_deploy_candidates:
        return
    cfg = common.read_config()
    deploy_repo = cfg.get("AGENT_DEPLOY_CANDIDATE_REPO", repo)
    if repo != deploy_repo:
        return
    common.run(
        [
            str(common.RUNTIME_DIR / "atlas-agent-workflow"),
            "run",
            repo,
            cfg.get("AGENT_DEPLOY_CANDIDATE_WORKFLOW", "agentic-deploy-candidate.yml"),
            "--ref",
            common.default_base_branch(repo),
            "-f",
            "dry_run=true",
            "--download-artifacts",
        ]
    )


def process_once(args: argparse.Namespace) -> int:
    processed = 0
    queued = 0
    max_per_repo = getattr(args, "max_per_repo", 1)
    lease_stale_seconds = getattr(args, "lease_stale_seconds", 6 * 60 * 60)
    dispatch_preview = {
        "generated_at": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
        "next_runnable": [],
        "blocked": [],
        "counts": {"runnable": 0, "blocked": 0},
    }
    if args.triage_needs_human:
        triage_cmd = [str(common.RUNTIME_DIR / "atlas-agent-triage"), "--limit", str(args.limit)]
        if args.repos_file:
            triage_cmd.extend(["--repos-file", args.repos_file])
        if args.triage_apply_stale and not getattr(args, "dry_run", False):
            triage_cmd.append("--apply-stale")
        if args.triage_approve_review_before_dispatch and not getattr(args, "dry_run", False):
            triage_cmd.append("--approve-review-before-dispatch")
        if args.triage_clean_pause_labels and not getattr(args, "dry_run", False):
            triage_cmd.append("--clean-pause-labels")
        if args.triage_comment and not getattr(args, "dry_run", False):
            triage_cmd.append("--comment")
        if args.triage_summary:
            triage_cmd.extend(["--summary", args.triage_summary])
        if args.triage_teams_preview:
            triage_cmd.append("--teams-preview")
        if args.triage_post_teams:
            triage_cmd.append("--post-teams")
        subprocess.run(triage_cmd, cwd=str(common.RUNTIME_DIR), check=False)

    for repo in target_repos(args.repos_file):
        repo_processed = 0
        if not getattr(args, "dry_run", False):
            ensure_agent_labels(repo)

        if args.auto_queue_label and queued < args.auto_queue_max:
            candidates = queue_candidate_issues(repo, args.auto_queue_label, args.limit)
            for issue in candidates:
                if maybe_queue_issue(repo, issue, args):
                    queued += 1
                if queued >= args.auto_queue_max:
                    break

        repo_failed = failed_issues(repo, args.limit) if args.inspect_failed else []
        if repo_failed is None:
            print(f"Skipping {repo}: failed issue query did not complete.", flush=True)
            continue
        repo_ready = ready_issues(repo, args.limit)
        if repo_ready is None:
            print(f"Skipping {repo}: ready issue query did not complete.", flush=True)
            continue
        blockers_by_number: dict[int, list[str]] = {}
        repo_runnable = 0
        for issue in repo_ready:
            execution_repo = execution_repo_for_issue(repo, issue)
            reasons = dispatch_blockers(
                repo,
                issue,
                args,
                check_open_pr=bool(args.auto_queue_skip_open_pr),
            )
            blockers_by_number[int(issue["number"])] = reasons
            if reasons:
                dispatch_preview["blocked"].append(dispatch_preview_record(repo, issue, reasons))
            elif repo_runnable < max_per_repo and len(dispatch_preview["next_runnable"]) < args.max_items:
                record = dispatch_preview_record(repo, issue, [])
                record["execution_repo"] = execution_repo
                dispatch_preview["next_runnable"].append(record)
                repo_runnable += 1
        dispatch_preview["counts"] = {
            "runnable": len(dispatch_preview["next_runnable"]),
            "blocked": len(dispatch_preview["blocked"]),
        }
        write_dispatch_preview(getattr(args, "triage_summary", None), dispatch_preview)
        print_dispatch_preview(dispatch_preview)

        if args.inspect_failed:
            for issue in repo_failed:
                labels = common.label_names(issue)
                reasons = failed_inspection_hard_reasons(
                    issue,
                    require_one_point=bool(getattr(args, "require_one_point", False)),
                )
                if reasons:
                    print(
                        f"Skipping failed inspection for {repo}#{issue['number']}: {', '.join(reasons)}.",
                        flush=True,
                    )
                    continue
                admin_inspect(
                    repo,
                    issue["number"],
                    args.auto_create_missing_base,
                    args.auto_allow_policy_labels,
                )

        for issue in repo_ready:
            if repo_processed >= max_per_repo:
                break
            labels = common.label_names(issue)
            reasons = blockers_by_number.get(int(issue["number"]), [])
            if "agent:running" in labels or reasons:
                if reasons:
                    print(f"Skipping {repo}#{issue['number']}: {', '.join(reasons)}.", flush=True)
                    if not getattr(args, "dry_run", False) and not any("missing policy allow label" in reason for reason in reasons):
                        common.run(
                            ["gh", "issue", "edit", str(issue["number"]), "--repo", repo, "--remove-label", "agent:ready"],
                            check=False,
                        )
                continue
            if getattr(args, "dry_run", False):
                execution_repo = execution_repo_for_issue(repo, issue)
                print(
                    f"DRY-RUN process {repo}#{issue['number']} in {execution_repo}: {issue['title']}",
                    flush=True,
                )
                processed += 1
                repo_processed += 1
                if processed >= args.max_items:
                    return processed
                continue
            execution_repo = execution_repo_for_issue(repo, issue)
            print(f"Processing {repo}#{issue['number']} in {execution_repo}: {issue['title']}")
            lease = acquire_issue_lease(repo, issue, lease_stale_seconds)
            if not lease:
                continue
            if args.auto_queue_skip_open_pr and has_open_pr_for_issue(repo, issue["number"]):
                print(f"Skipping {repo}#{issue['number']}: open PR appeared before worker start.", flush=True)
                release_issue_lease(lease)
                common.run(
                    ["gh", "issue", "edit", str(issue["number"]), "--repo", repo, "--remove-label", "agent:ready"],
                    check=False,
                )
                continue
            base_branch = dispatch_base_branch(execution_repo, issue)
            scope_lease: list[Path] = []
            if getattr(args, "write_scope_locks", True):
                scope_lease, scope_blocker = acquire_write_scope_lease(
                    execution_repo,
                    issue,
                    base_branch,
                    lease_stale_seconds,
                )
                if scope_blocker:
                    print(f"Skipping {repo}#{issue['number']}: {scope_blocker}.", flush=True)
                    release_issue_lease(lease)
                    continue
            maybe_dispatch_deploy_candidate(repo, issue, args)
            common.update_issue_automation_state(repo, int(issue["number"]), "Running", status="In Progress")
            try:
                rc = run_worker(
                    repo,
                    execution_repo,
                    issue["number"],
                    publish=args.publish,
                    base_branch=common.issue_body_base_branch(issue),
                )
                processed += 1
                repo_processed += 1
                notify_worker_result(repo, issue, rc)
                if rc != 0:
                    admin_inspect(
                        repo,
                        issue["number"],
                        args.auto_create_missing_base,
                        args.auto_allow_policy_labels,
                    )
            finally:
                release_write_scope_lease(scope_lease)
                release_issue_lease(lease)
            if processed >= args.max_items:
                return processed
    return processed


def main() -> None:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--once", action="store_true")
    parser.add_argument("--daemon", action="store_true")
    parser.add_argument("--publish", action="store_true", help="Create draft PRs instead of dry-run comments.")
    parser.add_argument("--dry-run", action="store_true", help="Preview queue/dispatch decisions without mutating labels or running workers.")
    parser.add_argument("--repos-file")
    parser.add_argument("--limit", type=int, default=20)
    parser.add_argument("--max-items", type=int, default=3)
    parser.add_argument("--max-per-repo", type=int, default=1)
    parser.add_argument("--lease-stale-seconds", type=int, default=6 * 60 * 60)
    parser.add_argument(
        "--write-scope-locks",
        action=argparse.BooleanOptionalAction,
        default=True,
        help="Prevent concurrent workers on the same repo/base when issue Write Scope values overlap or are unknown.",
    )
    parser.add_argument("--sleep-seconds", type=int, default=60)
    parser.add_argument("--inspect-failed", action="store_true")
    parser.add_argument(
        "--auto-queue-label",
        help="Promote open issues with this label to agent:ready when they are not already in an agent terminal/active state.",
    )
    parser.add_argument("--auto-queue-max", type=int, default=1)
    parser.add_argument(
        "--auto-queue-skip-open-pr",
        action=argparse.BooleanOptionalAction,
        default=True,
        help="Skip auto-queueing issues that appear to already have an open linked PR.",
    )
    parser.add_argument(
        "--require-one-point",
        action=argparse.BooleanOptionalAction,
        default=False,
        help="Only queue or dispatch issues marked points:1 or agent:one-point.",
    )
    parser.add_argument(
        "--auto-create-missing-base",
        action="store_true",
        help="When admin inspection finds a missing requested base branch, create it from the repo default and requeue.",
    )
    parser.add_argument(
        "--auto-allow-policy-labels",
        action="store_true",
        help="When admin inspection finds trusted high-risk issue metadata, add explicit agent:allow-* labels and requeue.",
    )
    parser.add_argument(
        "--dispatch-deploy-candidates",
        action="store_true",
        help="For issues requiring deployed validation, dispatch configured deploy candidate dry-runs.",
    )
    parser.add_argument(
        "--triage-needs-human",
        action="store_true",
        help="Run local needs-human triage once per loop before queueing issues.",
    )
    parser.add_argument(
        "--triage-apply-stale",
        action="store_true",
        help="During needs-human triage, remove stale needs-human labels and requeue only issues with no hard blockers.",
    )
    parser.add_argument(
        "--triage-approve-review-before-dispatch",
        action="store_true",
        help="Approve and queue trusted review-before-dispatch issues that have no other hard blockers.",
    )
    parser.add_argument(
        "--triage-clean-pause-labels",
        action="store_true",
        default=True,
        help="Remove stale agent active/failed labels from intentionally needs-human issues during triage.",
    )
    parser.add_argument(
        "--triage-comment",
        action="store_true",
        help="Comment when stale needs-human triage requeues an issue.",
    )
    parser.add_argument(
        "--triage-summary",
        help="Write a Teams-compatible needs-human blocker summary JSON during triage.",
    )
    parser.add_argument(
        "--triage-teams-preview",
        action="store_true",
        help="Build a local Teams payload preview from the triage summary.",
    )
    parser.add_argument(
        "--triage-post-teams",
        action="store_true",
        help="Post the triage Teams payload with local TEAMS_WEBHOOK_URL when configured.",
    )
    args = parser.parse_args()

    if not args.once and not args.daemon:
        args.once = True

    while True:
        count = process_once(args)
        stamp = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
        print(f"{stamp} Processed {count} issue(s).", flush=True)
        if args.once:
            return
        time.sleep(args.sleep_seconds)


if __name__ == "__main__":
    main()
