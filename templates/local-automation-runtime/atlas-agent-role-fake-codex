#!/usr/bin/env python3
"""Local fake Codex command for Atlas workflow-role smoke tests."""

from __future__ import annotations

import json
import os
import pathlib
import sys


def main() -> int:
    _prompt = sys.stdin.read()
    task_path = os.environ.get("ATLAS_ROLE_TASK_FILE")
    result_path = os.environ.get("ATLAS_ROLE_RESULT_FILE")
    if not task_path or not result_path:
        print("ATLAS_ROLE_TASK_FILE and ATLAS_ROLE_RESULT_FILE are required", file=sys.stderr)
        return 2
    task = json.loads(pathlib.Path(task_path).read_text(encoding="utf-8"))
    outputs = {str(name): f"fake evidence for {name}" for name in task.get("must_produce") or []}
    pathlib.Path(result_path).write_text(
        json.dumps(
            {
                "role_id": str(task.get("role_id") or ""),
                "status": "complete",
                "outputs": outputs,
                "evidence": [task_path],
                "notes": "Generated by atlas-agent-role-fake-codex for local smoke testing.",
            },
            indent=2,
            sort_keys=True,
        )
        + "\n",
        encoding="utf-8",
    )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
