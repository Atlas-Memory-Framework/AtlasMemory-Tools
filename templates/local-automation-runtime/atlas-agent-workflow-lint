#!/usr/bin/env python3
"""Lint Atlas workflow templates and optional agent references."""

from __future__ import annotations

import argparse
import json
import pathlib
import sys


RUNTIME_DIR = pathlib.Path(__file__).resolve().parent
if str(RUNTIME_DIR) not in sys.path:
    sys.path.insert(0, str(RUNTIME_DIR))

import atlas_workflows


def lint_templates(
    templates_path: str | pathlib.Path,
    *,
    agent_registry: str | pathlib.Path | None = None,
    agent_root: str | pathlib.Path | None = None,
) -> dict:
    templates = atlas_workflows.load_team_templates(templates_path)
    registry = atlas_workflows.load_agent_registry(agent_registry) if agent_registry else None
    template_records = []
    errors: list[str] = []
    for template in templates:
        template_errors = template.validate()
        template_errors.extend(
            atlas_workflows.validate_template_agent_refs(
                template,
                registry=registry,
                agent_root=agent_root,
            )
        )
        errors.extend(f"{template.id}: {error}" for error in template_errors)
        role_phases = template.role_phases() if not template_errors else []
        final_phase = set(role_phases[-1]) if role_phases else set()
        prior_roles = {role.id for role in template.roles if role.id not in final_phase}
        template_records.append(
            {
                "id": template.id,
                "workflow_kind": template.workflow_kind,
                "role_count": len(template.roles),
                "rollup_required": template.rollup_required(),
                "role_phases": role_phases,
                "rollup_roles": [
                    role.id
                    for role in template.roles
                    if template.rollup_required() and role.id in final_phase and prior_roles.issubset(set(role.consumes))
                ]
                if not template_errors
                else [],
                "errors": template_errors,
            }
        )
    return {
        "template_count": len(templates),
        "templates": template_records,
        "errors": errors,
    }


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--team-templates", default=str(RUNTIME_DIR / "team-templates"))
    parser.add_argument("--agent-registry")
    parser.add_argument("--agent-root")
    parser.add_argument("--json", action="store_true")
    return parser


def main(argv: list[str] | None = None) -> int:
    args = build_parser().parse_args(argv)
    summary = lint_templates(
        args.team_templates,
        agent_registry=args.agent_registry,
        agent_root=args.agent_root,
    )
    if args.json:
        print(json.dumps(summary, indent=2, sort_keys=True))
    else:
        print(f"Checked {summary['template_count']} workflow template(s).")
        for template in summary["templates"]:
            status = "ok" if not template["errors"] else "failed"
            print(f"- {template['id']} ({template['workflow_kind']}): {status}")
            if template["role_phases"]:
                phase_text = " | ".join(", ".join(phase) for phase in template["role_phases"])
                print(f"  phases: {phase_text}")
            if template.get("rollup_roles"):
                print(f"  rollup: {', '.join(template['rollup_roles'])}")
            for error in template["errors"]:
                print(f"  - {error}")
    return 1 if summary["errors"] else 0


if __name__ == "__main__":
    raise SystemExit(main())
