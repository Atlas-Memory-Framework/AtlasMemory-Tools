def local_validation_targets_from_summary(path: Path, limit: int) -> list[str]:
    if not path.exists():
        return []
    payload = json.loads(path.read_text(encoding="utf-8"))
    targets: list[str] = []
    for decision in payload.get("decisions") or []:
        if decision_route(decision) != "local-validate":
            continue
        repo = str(decision.get("repo") or "")
        number = decision.get("number")
        if repo and number:
            targets.append(f"{repo}#{int(number)}")
        if len(targets) >= limit:
            break
    return targets


