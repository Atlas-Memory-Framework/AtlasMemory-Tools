def target_repos(path: str | None) -> list[str]:
    repo_file = Path(path) if path else common.RUNTIME_DIR / "repos.txt"
    repos: list[str] = []
    for raw in repo_file.read_text(encoding="utf-8").splitlines():
        line = raw.split("#", 1)[0].strip()
        if line:
            repos.append(line)
    return repos


def safe_repo_name(repo: str) -> str:
    return repo.replace("/", "__")


def parse_stages(raw: str | None) -> list[str]:
    if not raw:
        return list(DEFAULT_STAGES)
    stages = [stage.strip() for stage in raw.split(",") if stage.strip()]
    allowed = {
        "reconcile",
        "project-reconcile",
        "decompose",
        "dependency-promote",
        "dispatch",
        "review",
        "semantic-review",
        "local-validate",
        "deployed-validate",
        "repair",
        "finalize",
        "summary",
    }
    unknown = [stage for stage in stages if stage not in allowed]
    if unknown:
        raise ValueError(f"Unknown stage(s): {', '.join(unknown)}")
    return stages


def build_dispatch_commands(args: argparse.Namespace, chain_dir: Path, chain_id: str, cycle: int) -> list[CommandSpec]:
    commands: list[CommandSpec] = []
    for repo in target_repos(args.repos_file):
        safe_name = safe_repo_name(repo)
        shard_file = chain_dir / f"{safe_name}.repos.txt"
        shard_file.write_text(repo + "\n", encoding="utf-8")
        summary_file = chain_dir / f"local-needs-human-summary-{safe_name}-cycle-{cycle}.json"
        for lane in range(1, args.max_per_repo + 1):
            cmd = [
                str(common.RUNTIME_DIR / "atlas-agent-orchestrator"),
                "--once",
                "--triage-needs-human",
                "--triage-summary",
                str(summary_file),
                "--auto-queue-label",
                args.auto_queue_label,
                "--auto-queue-max",
                "1",
                "--max-per-repo",
                "1",
                "--limit",
                str(args.limit),
                "--repos-file",
                str(shard_file),
            ]
            if args.publish and not args.dry_run:
                cmd.extend(
                    [
                        "--inspect-failed",
                        "--auto-create-missing-base",
                        "--triage-apply-stale",
                        "--triage-approve-review-before-dispatch",
                    ]
                )
            else:
                cmd.append("--dry-run")
            if args.require_one_point:
                cmd.append("--require-one-point")
            if args.publish and not args.dry_run:
                cmd.insert(2, "--publish")
            if args.post_triage_teams_per_repo:
                cmd.extend(["--triage-teams-preview", "--triage-post-teams"])
            commands.append(
                CommandSpec(
                    name=f"{repo}/lane-{lane}",
                    args=cmd,
                    log_file=common.logs_dir() / f"unattended-{chain_id}-{safe_name}-cycle-{cycle}-lane-{lane}.log",
                    summary_file=summary_file,
                )
            )
    return commands


