def decision_route(decision: dict[str, Any]) -> str:
    route = str(decision.get("route") or "")
    if route:
        return route
    label = str(decision.get("label") or "")
    if label == LOCAL_VALIDATION_REQUIRED_LABEL:
        return "local-validate"
    if label == MANUAL_VALIDATION_REQUIRED_LABEL:
        return "deployed-validate"
    if label == SEMANTIC_REVIEW_REQUIRED_LABEL:
        return "semantic-review"
    if label == NEEDS_REPAIR_LABEL and repairable_review_decision(decision):
        return "repair"
    if label == "agent:review-approved":
        return "approved"
    return "human"


