def deployed_validation_configured_repos(path: str | Path) -> tuple[set[str], bool]:
    config_path = Path(path)
    if not config_path.exists():
        return set(), False
    try:
        payload = json.loads(config_path.read_text(encoding="utf-8"))
    except json.JSONDecodeError:
        return set(), False
    if not isinstance(payload, dict):
        return set(), False
    repos = {str(repo) for repo in payload if repo != "*"}
    return repos, "*" in payload


def deployed_validation_targets_from_summary(path: Path, limit: int, configured_repos: set[str] | None = None, wildcard: bool = True) -> list[str]:
    if not path.exists():
        return []
    payload = json.loads(path.read_text(encoding="utf-8"))
    targets: list[str] = []
    for decision in payload.get("decisions") or []:
        if decision_route(decision) != "deployed-validate":
            continue
        repo = str(decision.get("repo") or "")
        number = decision.get("number")
        if not wildcard and repo not in (configured_repos or set()):
            continue
        if repo and number:
            targets.append(f"{repo}#{int(number)}")
        if len(targets) >= limit:
            break
    return targets


