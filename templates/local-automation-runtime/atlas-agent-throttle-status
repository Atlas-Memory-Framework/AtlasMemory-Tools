#!/usr/bin/env python3
"""Print local GitHub API throttle state without calling GitHub."""

from __future__ import annotations

import argparse
import json
from datetime import datetime, timezone
from typing import Any

import atlas_agent_common as common


def format_epoch(value: Any) -> str:
    if not value:
        return "none"
    return datetime.fromtimestamp(float(value), timezone.utc).isoformat()


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--json", action="store_true", help="Print machine-readable status.")
    parser.add_argument("--stale-seconds", type=float, default=120.0)
    args = parser.parse_args()

    status = common.github_throttle_status(stale_seconds=args.stale_seconds)
    if args.json:
        print(json.dumps(status, indent=2, sort_keys=True))
        return 0

    lock = status["stale_lock"]
    print(f"state_path: {status['state_path']}")
    print(f"state_exists: {status['exists']}")
    print(f"pause_until: {format_epoch(status['pause_until'])}")
    print(f"pause_remaining_seconds: {status['pause_remaining_seconds']:.1f}")
    print(f"next_allowed_at: {format_epoch(status['next_allowed_at'])}")
    print(f"next_allowed_remaining_seconds: {status['next_allowed_remaining_seconds']:.1f}")
    print(f"lock_exists: {lock['exists']}")
    print(f"lock_stale: {lock['stale']}")
    print(f"lock_age_seconds: {lock['age_seconds'] if lock['age_seconds'] is not None else 'none'}")
    print(f"last_command: {status['last_command'] or 'none'}")
    print(f"last_rate_limit_command: {status['last_rate_limit_command'] or 'none'}")
    print(f"last_rate_limit_at: {status['last_rate_limit_at'] or 'none'}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
