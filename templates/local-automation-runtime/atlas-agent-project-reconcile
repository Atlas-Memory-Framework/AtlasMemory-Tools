@dataclass
class ProjectConfig:
    project_id: str
    status_field_id: str
    status_options: dict[str, str]
    execution_state_field_id: str | None
    execution_state_options: dict[str, str]
    fields: dict[str, dict[str, Any]] = field(default_factory=dict)


@dataclass
class ProjectDecision:
    owner: str
    project_number: int
    project_id: str
    item_id: str
    repo: str
    number: int
    title: str
    action: str
    status_from: str
    status_to: str
    reasons: list[str]
    child_refs: list[str]
    field_updates: dict[str, str] | None = None


def project_targets(path: str | None, owner: str, project_number: int) -> list[tuple[str, int]]:
    if not path:
        return [(owner, project_number)]
    target_file = Path(path)
    targets: list[tuple[str, int]] = []
    for raw in target_file.read_text(encoding="utf-8").splitlines():
        line = raw.split("#", 1)[0].strip()
        if not line:
            continue
        if "/" in line:
            target_owner, raw_number = line.rsplit("/", 1)
        else:
            parts = line.split()
            if len(parts) != 2:
                raise ValueError(f"Project target must look like OWNER/NUMBER or 'OWNER NUMBER': {raw}")
            target_owner, raw_number = parts
        targets.append((target_owner.strip(), int(raw_number.strip())))
    return targets


def project_info(owner: str, project_number: int) -> dict[str, Any]:
    projects = common.gh_json(
        ["project", "list", "--owner", owner, "--format", "json", "--limit", "100"],
        retries=2,
    ).get("projects") or []
    for project in projects:
        if int(project.get("number") or 0) == project_number:
            return project
    raise RuntimeError(f"Project not found: {owner}/{project_number}")


def project_fields(owner: str, project_number: int) -> list[dict[str, Any]]:
    return (common.gh_json(
        ["project", "field-list", str(project_number), "--owner", owner, "--format", "json", "--limit", "100"],
        retries=2,
    ).get("fields") or [])


def project_config(owner: str, project_number: int) -> ProjectConfig:
    info = project_info(owner, project_number)
    fields = project_fields(owner, project_number)
    fields_by_name = {str(field.get("name")): field for field in fields}
    status_field = next((field for field in fields if field.get("name") == "Status"), None)
    if not status_field:
        raise RuntimeError("Project Status field was not found")
    execution_field = next((field for field in fields if field.get("name") == "ExecutionState"), None)
    return ProjectConfig(
        project_id=str(info["id"]),
        status_field_id=str(status_field["id"]),
        status_options={str(option["name"]): str(option["id"]) for option in status_field.get("options") or []},
        execution_state_field_id=str(execution_field["id"]) if execution_field else None,
        execution_state_options={
            str(option["name"]): str(option["id"]) for option in (execution_field or {}).get("options") or []
        },
        fields=fields_by_name,
    )


