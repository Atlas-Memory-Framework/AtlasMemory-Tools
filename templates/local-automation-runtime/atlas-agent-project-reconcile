def inferred_project_fields(items: list[dict[str, Any]]) -> list[dict[str, Any]]:
    names = set(PROJECT_RECONCILE_FIELDS)
    for item in items:
        for key in item:
            if not key or key in {"id", "content", "labels", "title"}:
                continue
            names.add(key[:1].upper() + key[1:])
    return [{"id": name, "name": name, "options": []} for name in sorted(names)]


def snapshot_project_config(path: str, owner: str, project_number: int, *, allow_inferred: bool) -> ProjectConfig:
    payload = common.read_project_snapshot(path)
    project = payload.get("project") or {}
    fields = common.project_snapshot_fields(path)
    items = common.project_snapshot_items(path, owner, project_number)
    if not fields and allow_inferred:
        fields = inferred_project_fields(items)
    if not fields:
        raise RuntimeError(
            "--project-snapshot must include Project field metadata for --apply; "
            "run a live reconcile or save a snapshot with fields."
        )
    fields_by_name = {str(field.get("name")): field for field in fields}
    status_field = fields_by_name.get("Status") or {"id": "Status", "options": []}
    execution_field = fields_by_name.get("ExecutionState")
    status_options = {str(option["name"]): str(option["id"]) for option in status_field.get("options") or []}
    if allow_inferred and not status_options:
        status_options = {name: name for name in ("Todo", "In Progress", "Done")}
    execution_options = {
        str(option["name"]): str(option["id"]) for option in (execution_field or {}).get("options") or []
    }
    return ProjectConfig(
        project_id=str(project.get("id") or payload.get("project_id") or "SNAPSHOT"),
        status_field_id=str(status_field.get("id") or "Status"),
        status_options=status_options,
        execution_state_field_id=str(execution_field.get("id")) if execution_field else None,
        execution_state_options=execution_options,
        fields=fields_by_name,
    )


def project_items(owner: str, project_number: int, limit: int) -> list[dict[str, Any]]:
    items = common.gh_json(
        ["project", "item-list", str(project_number), "--owner", owner, "--format", "json", "--limit", str(limit)],
        retries=2,
    ).get("items") or []
    if len(items) >= limit:
        print(
            f"PROJECT-RECONCILE warning: scanned item limit {limit} for {owner}/{project_number}; "
            "raise --limit or AGENT_PROJECT_ITEM_LIMIT if newer Project cards are missing.",
            flush=True,
        )
    return items


def issue_key(item: dict[str, Any]) -> tuple[str, int] | None:
    content = item.get("content") or {}
    repo = content.get("repository")
    number = content.get("number")
    if repo and number:
        return str(repo), int(number)
    return None


def issue_filter(raw: str) -> tuple[str | None, int]:
    text = str(raw).strip()
    url_match = re.match(r"^https://github\.com/(?P<repo>[^/]+/[^/]+)/issues/(?P<number>\d+)(?:\b|$)", text)
    if url_match:
        return url_match.group("repo"), int(url_match.group("number"))
    if text.startswith("#"):
        text = text[1:]
    ref_match = re.match(r"^(?:(?P<repo>[^#\s]+/[^#\s]+)#)?(?P<number>\d+)$", text)
    if not ref_match:
        raise ValueError(f"Issue filter must be NUMBER, #NUMBER, OWNER/REPO#NUMBER, or a GitHub issue URL: {raw}")
    return ref_match.group("repo"), int(ref_match.group("number"))


def item_matches_issue_filters(item: dict[str, Any], filters: set[tuple[str | None, int]]) -> bool:
    if not filters:
        return True
    key = issue_key(item)
    if not key:
        return False
    repo, number = key
    return any(number == filter_number and (filter_repo is None or repo == filter_repo) for filter_repo, filter_number in filters)


def issue_ref(item: dict[str, Any]) -> str:
    key = issue_key(item)
    if not key:
        return "unknown"
    return f"{key[0]}#{key[1]}"


def item_value(item: dict[str, Any], field: str) -> str:
    key = field[:1].lower() + field[1:]
    value = item.get(key)
    if value is None:
        value = item.get(field)
    if value is None:
        return ""
    if isinstance(value, list):
        return "\n".join(str(part) for part in value if str(part).strip())
    return str(value)


def first_body_field(body: str, *fields: str) -> str:
    for field in fields:
        for value in common.body_field_values(body, field):
            cleaned = value.strip().strip("`").strip()
            if cleaned and cleaned.lower() not in common.NONE_FIELD_VALUES:
                return cleaned
    return ""


def labels_for_item(item: dict[str, Any]) -> set[str]:
    labels: set[str] = set()
    for label in item.get("labels") or []:
        if isinstance(label, dict):
            name = label.get("name")
        else:
            name = label
        if name:
            labels.add(str(name))
    return labels


def issue_title(item: dict[str, Any]) -> str:
    return str((item.get("content") or {}).get("title") or item.get("title") or "")


def bracket_source_id(title: str) -> str:
    match = re.match(r"^\[([^\]]+)\]", title.strip())
    return match.group(1).strip() if match else ""


def normalized_workstream(labels: set[str], title: str) -> str:
    for label in sorted(labels):
        if label.startswith("workstream:"):
            return label.split(":", 1)[1].strip().upper()
    source_id = bracket_source_id(title)
    if source_id:
        parts = source_id.split("-")
        if len(parts) >= 3 and parts[0].upper().startswith("WS"):
            return "-".join(parts[:3]).upper()
    return ""


def item_type_from(labels: set[str], title: str) -> str:
    if "type:epic" in labels or title.startswith("[Epic]"):
        return "Epic"
    if "type:tracker" in labels or title.startswith("[Tracker]"):
        return "Tracker"
    if "type:spike" in labels:
        return "Spike"
    if "type:story" in labels or bracket_source_id(title):
        return "Story"
    return ""


def gate_tier_from(labels: set[str]) -> str:
    for label in sorted(labels):
        if label.startswith("tier:t"):
            return label.split(":", 1)[1].upper()
    return ""


def label_value(labels: set[str], prefix: str) -> str:
    for label in sorted(labels):
        if label.startswith(prefix):
            return label.split(":", 1)[1].strip()
    return ""


def risk_from_tags(raw_tags: str) -> str:
    tags = {tag.strip().lower() for tag in re.split(r"[,;\n]+", raw_tags or "") if tag.strip()}
    if tags & {"auth", "secrets", "migration", "cross-repo", "needs-deployed-validation", "ui-surface"}:
        return "High"
    if tags:
        return "Medium"
    return ""


def priority_from_gate_tier(gate_tier: str) -> str:
    match = re.search(r"(\d+)", gate_tier or "")
    if not match:
        return ""
    tier = int(match.group(1))
    if tier <= 1:
        return "P1"
    if tier <= 3:
        return "P2"
    return "P3"


def section_text(body: str, heading: str) -> str:
    pattern = rf"(?ims)^##\s+{re.escape(heading)}\s*$\n(?P<body>.*?)(?=^##\s+|\Z)"
    match = re.search(pattern, body)
    if not match:
        return ""
    items: list[str] = []
    for raw in match.group("body").splitlines():
        line = raw.strip()
        if not line:
            if items:
                break
            continue
        if not line.startswith("-"):
            if items:
                break
            continue
        item = line.lstrip("-").strip().strip("`").strip()
        if item and item.lower() not in common.NONE_FIELD_VALUES:
            items.append(item)
    return "\n".join(items)


def section_body_text(body: str, heading: str) -> str:
    pattern = rf"(?ims)^##\s+{re.escape(heading)}\s*$\n(?P<body>.*?)(?=^##\s+|\Z)"
    match = re.search(pattern, body)
    if not match:
        return ""
    return match.group("body").strip()


def section_url(body: str, heading: str) -> str:
    text = section_body_text(body, heading)
    match = re.search(r"https://github\.com/[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+/issues/\d+", text)
    return match.group(0) if match else ""


def parent_issue_refs(item: dict[str, Any]) -> list[tuple[str, int]]:
    key = issue_key(item)
    if not key:
        return []
    repo, _number = key
    body = str((item.get("content") or {}).get("body") or "")
    refs: list[tuple[str, int]] = []
    seen: set[tuple[str, int]] = set()
    for match in re.finditer(r"https://github\.com/([A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+)/issues/(\d+)", body):
        ref = (match.group(1), int(match.group(2)))
        if ref not in seen:
            seen.add(ref)
            refs.append(ref)
    for match in re.finditer(r"(?im)^\s*(?:-\s*)?(?:Parent issue|Parent):\s*`?#(\d+)`?\s*$", body):
        ref = (repo, int(match.group(1)))
        if ref not in seen:
            seen.add(ref)
            refs.append(ref)
    return refs


INHERITED_PROJECT_FIELDS = (
    "Workstream",
    "TargetRepo",
    "ExecutionRepo",
    "BaseBranch",
    "PlanKey",
    "ParentEpic",
    "ReviewGates",
    "GateTier",
    "Risk",
    "RiskTags",
    "ValidationScope",
    "Priority",
)


def item_project_value(item: dict[str, Any], field: str) -> str:
    return item_value(item, field).strip()


def item_body_value(item: dict[str, Any], field: str) -> str:
    body = str((item.get("content") or {}).get("body") or "")
    title = issue_title(item)
    labels = labels_for_item(item)
    repo = str((item.get("content") or {}).get("repository") or "")
    if field == "Workstream":
        return normalized_workstream(labels, title)
    if field == "TargetRepo":
        return first_body_field(body, "Target repo(s)", "Target repo") or repo
    if field == "ExecutionRepo":
        target_repo = first_body_field(body, "Target repo(s)", "Target repo") or repo
        return first_body_field(body, "Execution repo") or target_repo
    if field == "BaseBranch":
        return first_body_field(body, "Base branch")
    if field == "PlanKey":
        return first_body_field(body, "Plan key")
    if field == "ParentEpic":
        return section_url(body, "Parent Epic")
    if field == "ReviewGates":
        return section_text(body, "Named Gates") or section_text(body, "Required Gates")
    if field == "GateTier":
        return gate_tier_from(labels)
    if field == "RiskTags":
        return first_body_field(body, "Risk tags")
    if field == "Risk":
        return risk_from_tags(first_body_field(body, "Risk tags"))
    if field == "ValidationScope":
        return first_body_field(body, "Validation scope")
    if field == "Priority":
        priority = first_body_field(body, "Priority") or label_value(labels, "priority:")
        if priority:
            return priority.upper()
        return priority_from_gate_tier(gate_tier_from(labels))
    return ""


def priority_workstream_key(workstream: str) -> str:
    cleaned = workstream.strip().upper()
    return re.sub(r"-\d+$", "", cleaned)


def inherited_project_metadata(
    item: dict[str, Any],
    items_by_issue: dict[tuple[str, int], dict[str, Any]],
    priority_by_workstream: dict[str, str],
) -> dict[str, str]:
    inherited: dict[str, str] = {}
    for ref in parent_issue_refs(item):
        parent = items_by_issue.get(ref)
        if not parent:
            continue
        for field in INHERITED_PROJECT_FIELDS:
            value = item_project_value(parent, field) or item_body_value(parent, field)
            if value and field not in inherited:
                inherited[field] = value
    workstream = priority_workstream_key(
        item_project_value(item, "Workstream") or item_body_value(item, "Workstream")
    )
    if workstream and "Priority" not in inherited:
        priority = priority_by_workstream.get(workstream)
        if priority:
            inherited["Priority"] = priority
    return inherited


def issue_ready_from(body: str, labels: set[str]) -> str:
    raw = first_body_field(body, "Issue ready").lower()
    if raw == "true":
        return "Ready"
    if raw == "false":
        return "Blocked"
    if "status:ready" in labels or "agent:ready" in labels:
        return "Ready"
    if "status:blocked" in labels:
        return "Blocked"
    return ""


def latest_pr_for_issue(repo: str, number: int) -> dict[str, Any] | None:
    prs = common.gh_json_or_none(
        [
            "pr",
            "list",
            "--repo",
            repo,
            "--state",
            "all",
            "--search",
            f"#{number}",
            "--limit",
            "20",
            "--json",
            "number,title,url,state,isDraft,mergedAt,labels,updatedAt,headRefName",
        ],
        retries=2,
    ) or []
    title_prefix = f"agent: #{number} "
    head_prefix = f"agent/issue-{number}/"
    for pr in prs:
        title = str(pr.get("title") or "")
        head = str(pr.get("headRefName") or "")
        if title.startswith(title_prefix) or head.startswith(head_prefix):
            return pr
    return None


def completion_pr_urls(item: dict[str, Any]) -> list[str]:
    body = str((item.get("content") or {}).get("body") or "")
    values: list[str] = []
    for field in ("Completed by", "Completion PR", "Completion PRs", "Merged PR", "Merged PRs"):
        values.extend(common.body_field_values(body, field))
    urls: list[str] = []
    seen: set[str] = set()
    for value in values:
        for url in re.findall(r"https://github\.com/[^/\s]+/[^/\s]+/pull/\d+", value):
            if url not in seen:
                seen.add(url)
                urls.append(url)
        for ref in re.findall(r"(?<![\w/-])([A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+#\d+)", value):
            repo, number = ref.rsplit("#", 1)
            url = f"https://github.com/{repo}/pull/{number}"
            if url not in seen:
                seen.add(url)
                urls.append(url)
    return urls


def pr_label_names(pr: dict[str, Any] | None) -> set[str]:
    labels: set[str] = set()
    for label in (pr or {}).get("labels") or []:
        if isinstance(label, dict):
            name = label.get("name")
        else:
            name = label
        if name:
            labels.add(str(name))
    return labels


def should_lookup_pr(item: dict[str, Any], issue_state_value: str) -> bool:
    labels = labels_for_item(item)
    if "agent:pr-open" in labels or "agent:running" in labels:
        return True
    if issue_state_value == "CLOSED":
        return bool(item_value(item, "ActivePR")) or item_value(item, "ReviewVerdict") != "Merged"
    return item_value(item, "AutomationState") == "PR Open" or item_value(item, "Status") == "In Progress"


def desired_metadata(
    item: dict[str, Any],
    issue_state_value: str,
    pr: dict[str, Any] | None,
    inherited: dict[str, str] | None = None,
) -> dict[str, str]:
    content = item.get("content") or {}
    body = str(content.get("body") or "")
    title = issue_title(item)
    labels = labels_for_item(item)
    repo = str(content.get("repository") or "")
    points = common.issue_points({"body": body, "labels": [{"name": label} for label in labels]})
    dispatch_mode = first_body_field(body, "Dispatch mode")
    dispatch_recommendation = first_body_field(body, "Dispatch recommendation")
    open_dependencies = first_body_field(body, "Open dependencies")
    target_repo = first_body_field(body, "Target repo(s)", "Target repo") or repo
    execution_repo = first_body_field(body, "Execution repo") or target_repo
    plan_key = first_body_field(body, "Plan key")
    risk_tags = first_body_field(body, "Risk tags")
    validation_scope = first_body_field(body, "Validation scope")
    review_gates = section_text(body, "Named Gates") or section_text(body, "Required Gates")
    priority = first_body_field(body, "Priority") or label_value(labels, "priority:")
    parent_epic = section_url(body, "Parent Epic")
    pr_state = str((pr or {}).get("state") or "").upper()
    pr_labels = pr_label_names(pr)
    explicit_completion_prs = completion_pr_urls(item)
    completion_mode = first_body_field(body, "Completion mode")
    is_closed = issue_state_value == "CLOSED"
    has_pr = bool(pr)
    has_open_pr = pr_state == "OPEN"
    updates: dict[str, str] = {
        "ItemType": item_type_from(labels, title),
        "ExecutionState": item_type_from(labels, title),
        "Workstream": normalized_workstream(labels, title),
        "TargetRepo": target_repo,
        "ExecutionRepo": execution_repo,
        "BaseBranch": first_body_field(body, "Base branch"),
        "PlanKey": plan_key,
        "SourceId": bracket_source_id(title),
        "ParentEpic": parent_epic,
        "ReviewGates": review_gates,
        "GateTier": gate_tier_from(labels),
        "DispatchMode": dispatch_mode,
        "DispatchRecommendation": dispatch_recommendation,
        "DependsOn": "" if open_dependencies.lower() in {"", "none", "n/a", "na", "-"} else open_dependencies,
        "Priority": priority.upper() if priority else "",
        "Risk": risk_from_tags(risk_tags),
        "RiskTags": risk_tags,
        "ValidationScope": validation_scope,
        "IssueReady": issue_ready_from(body, labels),
        "WriteScope": section_text(body, "Write Scope"),
        "Validation": section_text(body, "Validation Commands"),
        "CompletionMode": completion_mode,
        "CompletedBy": "\n".join(explicit_completion_prs),
    }
    if points is not None:
        updates["Size"] = str(points)
        if points == 1 or "agent:one-point" in labels:
            updates["OnePRContract"] = "Yes"
    if is_closed:
        updates["Status"] = "Done"
        updates["AutomationState"] = "Done"
        if has_pr:
            updates["ReviewVerdict"] = "Merged" if pr_state == "MERGED" else "Validated"
        elif explicit_completion_prs:
            updates["ReviewVerdict"] = "Merged"
    elif has_open_pr:
        updates["Status"] = "In Progress"
        updates["AutomationState"] = "PR Open"
        updates["ReviewVerdict"] = "Approved" if "agent:review-approved" in pr_labels else "Pending"
    elif "agent:failed" in labels:
        updates["AutomationState"] = "Failed"
    elif "agent:running" in labels:
        updates["Status"] = "In Progress"
        updates["AutomationState"] = "Running"
    elif "status:blocked" in labels or issue_ready_from(body, labels) == "Blocked":
        updates["AutomationState"] = "Blocked"
    elif issue_ready_from(body, labels) == "Ready":
        updates["AutomationState"] = "Ready"
    if has_pr:
        updates["ActivePR"] = str(pr.get("url") or "")
    elif explicit_completion_prs:
        updates["ActivePR"] = "\n".join(explicit_completion_prs)
    for field, value in (inherited or {}).items():
        if not updates.get(field):
            updates[field] = value
    if not updates.get("Priority"):
        updates["Priority"] = priority_from_gate_tier(updates.get("GateTier", ""))
    return {field: value for field, value in updates.items() if value}


ALWAYS_RECONCILE_FIELDS = {
    "Status",
    "AutomationState",
    "ActivePR",
    "ReviewVerdict",
    "SourceId",
    "Size",
    "CompletionMode",
    "CompletedBy",
}


def field_update_supported(config: ProjectConfig, field: str, value: str) -> bool:
    field_config = config.fields.get(field)
    if not field_config:
        return False
    if not value:
        return True
    options = {str(option.get("name")) for option in field_config.get("options") or []}
    return not options or value in options


def supported_field_updates(config: ProjectConfig, updates: dict[str, str]) -> dict[str, str]:
    return {field: value for field, value in updates.items() if field_update_supported(config, field, value)}


def parser_source_id(item: dict[str, Any]) -> str:
    return bracket_source_id(issue_title(item))


def stable_source_id(item: dict[str, Any]) -> str:
    return parser_source_id(item) or item_project_value(item, "SourceId")


def ready_signals(item: dict[str, Any]) -> set[str]:
    content = item.get("content") or {}
    body = str(content.get("body") or "")
    labels = labels_for_item(item)
    signals: set[str] = set()
    body_ready = first_body_field(body, "Issue ready").lower()
    if body_ready == "true":
        signals.add("body Issue ready=true")
    if "status:ready" in labels or "agent:ready" in labels:
        signals.add("ready label")
    if item_project_value(item, "IssueReady") == "Ready":
        signals.add("Project IssueReady=Ready")
    if item_project_value(item, "AutomationState") == "Ready":
        signals.add("Project AutomationState=Ready")
    if str(item.get("automationState") or "") == "Ready":
        signals.add("Project AutomationState=Ready")
    return signals


def normalized_dependency_value(value: str) -> str:
    cleaned = value.strip().strip("`").strip()
    return "" if cleaned.lower() in common.NONE_FIELD_VALUES else cleaned


def audit_block_updates(config: ProjectConfig, *, clear_size: bool = False) -> dict[str, str]:
    requested = {
        "AutomationState": "Blocked",
        "IssueReady": "Blocked",
    }
    if clear_size:
        requested["Size"] = ""
    return supported_field_updates(config, requested)


def audit_decision(
    owner: str,
    project_number: int,
    config: ProjectConfig,
    item: dict[str, Any],
    action: str,
    reasons: list[str],
    *,
    clear_size: bool = False,
    child_refs: list[str] | None = None,
) -> ProjectDecision:
    key = issue_key(item)
    repo, number = key if key else ("project-only", 0)
    return ProjectDecision(
        owner=owner,
        project_number=project_number,
        project_id=config.project_id,
        item_id=str(item.get("id") or ""),
        repo=repo,
        number=number,
        title=issue_title(item) or str(item.get("title") or ""),
        action=action,
        status_from=str(item.get("status") or ""),
        status_to=str(item.get("status") or ""),
        reasons=reasons,
        child_refs=child_refs or [],
        field_updates=audit_block_updates(config, clear_size=clear_size),
    )


def metadata_decisions(
    owner: str,
    project_number: int,
    config: ProjectConfig,
    items: list[dict[str, Any]],
    issue_states: dict[tuple[str, int], str],
    *,
    hydrate_metadata: bool,
    pr_lookup: bool = True,
    parent_keys_with_children: set[tuple[str, int]] | None = None,
) -> list[ProjectDecision]:
    if not hydrate_metadata or not config.fields:
        return []
    items_by_issue = {key: item for item in items if (key := issue_key(item))}
    priority_values_by_workstream: dict[str, set[str]] = {}
    for item in items:
        workstream = priority_workstream_key(
            item_project_value(item, "Workstream") or normalized_workstream(labels_for_item(item), issue_title(item))
        )
        priority = item_project_value(item, "Priority")
        if workstream and priority:
            priority_values_by_workstream.setdefault(workstream, set()).add(priority)
    priority_by_workstream = {
        workstream: next(iter(values))
        for workstream, values in priority_values_by_workstream.items()
        if len(values) == 1
    }
    decisions: list[ProjectDecision] = []
    for item in items:
        key = issue_key(item)
        if not key:
            continue
        repo, number = key
        pr = (
            None
            if completion_pr_urls(item)
            else latest_pr_for_issue(repo, number) if pr_lookup and should_lookup_pr(item, issue_states.get(key, "UNKNOWN")) else None
        )
        desired = desired_metadata(
            item,
            issue_states.get(key, "UNKNOWN"),
            pr,
            inherited_project_metadata(item, items_by_issue, priority_by_workstream),
        )
        if key in (parent_keys_with_children or set()):
            desired["Size"] = ""
        field_updates: dict[str, str] = {}
        for field, value in desired.items():
            field_config = config.fields.get(field)
            if not field_config:
                continue
            options = {str(option.get("name")) for option in field_config.get("options") or []}
            if options and value not in options:
                continue
            current = item_value(item, field)
            if field in ALWAYS_RECONCILE_FIELDS:
                if current != value:
                    field_updates[field] = value
            elif not current:
                field_updates[field] = value
        if not field_updates:
            continue
        decisions.append(
            ProjectDecision(
                owner=owner,
                project_number=project_number,
                project_id=config.project_id,
                item_id=str(item["id"]),
                repo=repo,
                number=number,
                title=issue_title(item),
                action="hydrate-metadata",
                status_from=str(item.get("status") or ""),
                status_to=str(field_updates.get("Status") or item.get("status") or ""),
                reasons=["Project issue row metadata is missing or stale"],
                child_refs=[],
                field_updates=field_updates,
            )
        )
    return decisions


def project_audit_decisions(
    owner: str,
    project_number: int,
    config: ProjectConfig,
    items: list[dict[str, Any]],
) -> list[ProjectDecision]:
    decisions: list[ProjectDecision] = []
    source_buckets: dict[str, list[dict[str, Any]]] = {}
    for item in items:
        source_id = stable_source_id(item)
        if source_id:
            source_buckets.setdefault(source_id, []).append(item)

    for source_id, rows in sorted(source_buckets.items()):
        if len(rows) < 2:
            continue
        refs = [issue_ref(row) for row in rows]
        for row in rows:
            decisions.append(
                audit_decision(
                    owner,
                    project_number,
                    config,
                    row,
                    "audit-duplicate-source-id",
                    [f"Duplicate Project SourceId {source_id}: {', '.join(refs)}"],
                    clear_size=True,
                )
            )

    for item in items:
        key = issue_key(item)
        source_from_parser = parser_source_id(item)
        source_from_project = item_project_value(item, "SourceId")
        current_size = item_project_value(item, "Size")
        signals = ready_signals(item)
        reasons: list[str] = []
        clear_size = False

        if not key:
            if source_from_project or current_size:
                reasons.append("Project-only row is not backed by an issue parser record")
                clear_size = True
        elif source_from_project and not source_from_parser:
            reasons.append("Project SourceId is not present in parser-derived issue truth")
            clear_size = True
        elif current_size and not source_from_parser:
            reasons.append("Project Size is not backed by parser-derived SourceId")
            clear_size = True
        elif signals and not source_from_parser:
            reasons.append("Ready issue is missing parser-derived SourceId")

        content = item.get("content") or {}
        body = str(content.get("body") or "")
        labels = labels_for_item(item)
        body_ready = first_body_field(body, "Issue ready").lower()
        if signals and body_ready == "false":
            reasons.append("Ready markers disagree with body Issue ready=false")
        if signals and "status:blocked" in labels:
            reasons.append("Ready markers disagree with status:blocked label")

        open_dependencies_values = common.body_field_values(body, "Open dependencies")
        body_depends = normalized_dependency_value(open_dependencies_values[0]) if open_dependencies_values else ""
        project_depends = normalized_dependency_value(item_project_value(item, "DependsOn"))
        if signals and re.search(r"(?im)^##\s+Dependencies\s*$", body) and not open_dependencies_values:
            reasons.append("Dependencies section is missing Open dependencies runtime marker")
        if signals and body_depends:
            reasons.append("Ready markers coexist with non-empty Open dependencies")
        if signals and project_depends and project_depends != body_depends:
            reasons.append("Project DependsOn disagrees with body Open dependencies")

        manual_gates = first_body_field(body, "Manual gates remaining")
        if signals and manual_gates:
            reasons.append("Ready markers coexist with non-empty Manual gates remaining")

        for field in ("DispatchMode", "DispatchRecommendation"):
            body_value = first_body_field(body, field.replace("Dispatch", "Dispatch ").lower().title())
            project_value = item_project_value(item, field)
            if signals and body_value and project_value and body_value != project_value:
                reasons.append(f"Project {field} disagrees with issue body")

        if signals:
            point_values = common.issue_point_values({"body": body, "labels": [{"name": label} for label in labels]})
            if len(point_values) > 1:
                joined = ", ".join(str(value) for value in sorted(point_values))
                reasons.append(f"Ready markers coexist with conflicting point metadata: {joined}")
                clear_size = True
            elif point_values and point_values[0] > 1:
                reasons.append(f"Ready markers coexist with multi-point Size {point_values[0]}")
                clear_size = True
            elif not point_values and "agent:one-point" not in labels:
                reasons.append("Ready markers coexist with missing point metadata")

            priority = item_project_value(item, "Priority") or item_body_value(item, "Priority")
            if not priority:
                priority = priority_from_gate_tier(item_project_value(item, "GateTier"))
            if not priority:
                reasons.append("Ready markers coexist with missing Priority metadata")
            elif "Priority" in config.fields and not field_update_supported(config, "Priority", priority):
                reasons.append(f"Inferred Priority {priority} is not available in Project options")

        if reasons:
            decisions.append(
                audit_decision(
                    owner,
                    project_number,
                    config,
                    item,
                    "audit-blocked",
                    reasons,
                    clear_size=clear_size,
                )
            )
    return decisions


def issue_url(item: dict[str, Any]) -> str:
    return str((item.get("content") or {}).get("url") or "")


def parent_urls(item: dict[str, Any]) -> list[str]:
    body = str((item.get("content") or {}).get("body") or "")
    urls = re.findall(r"https://github\.com/[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+/issues/\d+", body)
    seen: set[str] = set()
    result: list[str] = []
    for url in urls:
        if url not in seen:
            seen.add(url)
            result.append(url)
    return result


def is_epic_item(item: dict[str, Any]) -> bool:
    labels = set(item.get("labels") or [])
    title = str((item.get("content") or {}).get("title") or "")
    return (
        "type:epic" in labels
        or item.get("executionState") == "Epic"
        or title.startswith("[Epic]")
        or "[Epic]" in title
    )


def issue_state(repo: str, number: int) -> str:
    data = common.gh_json(
        ["issue", "view", str(number), "--repo", repo, "--json", "state"],
        retries=2,
    )
    return str(data.get("state") or "UNKNOWN").upper()


def issue_states_for_items(items: list[dict[str, Any]]) -> dict[tuple[str, int], str]:
    by_repo: dict[str, set[int]] = {}
    for item in items:
        key = issue_key(item)
        if key:
            repo, number = key
            by_repo.setdefault(repo, set()).add(number)
    issue_states: dict[tuple[str, int], str] = {}
    for repo, numbers in by_repo.items():
        expected = set(numbers)
        rows = common.gh_json_or_none(
            [
                "issue",
                "list",
                "--repo",
                repo,
                "--state",
                "all",
                "--limit",
                str(max(1000, len(expected))),
                "--json",
                "number,state",
            ],
            retries=2,
        ) or []
        for row in rows:
            number = int(row.get("number") or 0)
            if number in expected:
                issue_states[(repo, number)] = str(row.get("state") or "UNKNOWN").upper()
        for missing in sorted(expected - {number for item_repo, number in issue_states if item_repo == repo}):
            issue_states[(repo, missing)] = issue_state(repo, missing)
    return issue_states


def item_complete(item: dict[str, Any], issue_states: dict[tuple[str, int], str]) -> bool:
    key = issue_key(item)
    state = issue_states.get(key or ("", 0), "UNKNOWN")
    return item.get("status") == "Done" and state == "CLOSED"


def target_status_for_children(children: list[dict[str, Any]], issue_states: dict[tuple[str, int], str]) -> str:
    if any(not item_complete(child, issue_states) and child.get("status") == "In Progress" for child in children):
        return "In Progress"
    if any(issue_states.get(issue_key(child) or ("", 0)) == "OPEN" for child in children):
        return "In Progress"
    return "Todo"


def children_by_parent_issue(items: list[dict[str, Any]]) -> dict[tuple[str, int], list[dict[str, Any]]]:
    children: dict[tuple[str, int], list[dict[str, Any]]] = {}
    for item in items:
        for parent_ref in parent_issue_refs(item):
            children.setdefault(parent_ref, []).append(item)
    return children


def parent_size_rollup_decisions(
    owner: str,
    project_number: int,
    config: ProjectConfig,
    items: list[dict[str, Any]],
    children_by_parent: dict[tuple[str, int], list[dict[str, Any]]],
) -> list[ProjectDecision]:
    if "Size" not in config.fields:
        return []
    items_by_issue = {key: item for item in items if (key := issue_key(item))}
    decisions: list[ProjectDecision] = []
    for parent_key, children in sorted(children_by_parent.items()):
        parent = items_by_issue.get(parent_key)
        if not parent or not item_project_value(parent, "Size"):
            continue
        child_refs = [issue_ref(child) for child in children]
        decisions.append(
            ProjectDecision(
                owner=owner,
                project_number=project_number,
                project_id=config.project_id,
                item_id=str(parent["id"]),
                repo=parent_key[0],
                number=parent_key[1],
                title=issue_title(parent),
                action="clear-parent-size",
                status_from=str(parent.get("status") or ""),
                status_to=str(parent.get("status") or ""),
                reasons=["Decomposed child items supersede parent Size for rollups"],
                child_refs=child_refs,
                field_updates={"Size": ""},
            )
        )
    return decisions


def decide(
    owner: str,
    project_number: int,
    config: ProjectConfig,
    items: list[dict[str, Any]],
    *,
    hydrate_metadata: bool = True,
    pr_lookup: bool = True,
) -> list[ProjectDecision]:
    issue_states = issue_states_for_items(items)
    children_by_parent_key = children_by_parent_issue(items)

    by_url = {issue_url(item): item for item in items if issue_url(item)}
    children_by_parent: dict[str, list[dict[str, Any]]] = {}
    for item in items:
        for url in parent_urls(item):
            children_by_parent.setdefault(url, []).append(item)

    decisions: list[ProjectDecision] = metadata_decisions(
        owner,
        project_number,
        config,
        items,
        issue_states,
        hydrate_metadata=hydrate_metadata,
        pr_lookup=pr_lookup,
        parent_keys_with_children=set(children_by_parent_key),
    )
    decisions.extend(parent_size_rollup_decisions(owner, project_number, config, items, children_by_parent_key))
    decisions.extend(project_audit_decisions(owner, project_number, config, items))
    for parent_url, children in children_by_parent.items():
        parent = by_url.get(parent_url)
        if not parent or not is_epic_item(parent) or parent.get("status") != "Done":
            continue
        incomplete = [child for child in children if not item_complete(child, issue_states)]
        if not incomplete:
            continue
        target_status = target_status_for_children(incomplete, issue_states)
        if target_status not in config.status_options:
            continue
        key = issue_key(parent)
        if not key:
            continue
        decisions.append(
            ProjectDecision(
                owner=owner,
                project_number=project_number,
                project_id=config.project_id,
                item_id=str(parent["id"]),
                repo=key[0],
                number=key[1],
                title=str((parent.get("content") or {}).get("title") or ""),
                action="set-epic-status",
                status_from=str(parent.get("status") or ""),
                status_to=target_status,
                reasons=[f"{len(incomplete)} child item(s) are not complete"],
                child_refs=[issue_ref(child) for child in incomplete],
                field_updates={"Status": target_status},
            )
        )
    return decisions


def project_field_value_args(field_name: str, field: dict[str, Any], value: str) -> list[str]:
    if not value:
        return ["--clear"]
    if field_name == "Size":
        return ["--number", value]
    options = {str(option.get("name")): str(option.get("id")) for option in field.get("options") or []}
    if options:
        option_id = options.get(value)
        if not option_id:
            raise RuntimeError(f"Project field {field_name} has no option {value!r}")
        return ["--single-select-option-id", option_id]
    return ["--text", value]


def apply_project_field(config: ProjectConfig, item_id: str, field_name: str, value: str) -> None:
    field = config.fields.get(field_name)
    if not field:
        return
    try:
        common.run(
            [
                "gh",
                "project",
                "item-edit",
                "--id",
                item_id,
                "--project-id",
                config.project_id,
                "--field-id",
                str(field["id"]),
                *project_field_value_args(field_name, field, value),
            ],
            retries=3,
        )
    except RuntimeError as exc:
        if "Could not resolve to a node" in str(exc):
            print(f"SKIP PROJECT-RECONCILE {item_id}: Project item no longer exists while updating {field_name}")
            return
        raise


def apply_decision(decision: ProjectDecision, config: ProjectConfig) -> None:
    for field_name, value in (decision.field_updates or {}).items():
        apply_project_field(config, decision.item_id, field_name, value)


def write_summary(path: str, decisions: list[ProjectDecision]) -> None:
    common.write_json(
        Path(path),
        {
            "generated_at": common.now_id(),
            "decisions": [
                {
                    "owner": decision.owner,
                    "project_number": decision.project_number,
                    "repo": decision.repo,
                    "number": decision.number,
                    "title": decision.title,
                    "action": decision.action,
                    "status_from": decision.status_from,
                    "status_to": decision.status_to,
                    "reasons": decision.reasons,
                    "child_refs": decision.child_refs,
                    "field_updates": decision.field_updates or {},
                }
                for decision in decisions
            ],
        },
    )


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--owner", default=DEFAULT_OWNER)
    parser.add_argument("--project-number", type=int, default=DEFAULT_PROJECT_NUMBER)
    parser.add_argument(
        "--projects-file",
        help="Optional file of project targets, one per line as OWNER/NUMBER or 'OWNER NUMBER'.",
    )
    parser.add_argument(
        "--limit",
        type=int,
        default=common.config_int("AGENT_PROJECT_ITEM_LIMIT", DEFAULT_PROJECT_ITEM_LIMIT),
        help="Maximum GitHub Project items to scan.",
    )
    parser.add_argument(
        "--hydrate-metadata",
        action=argparse.BooleanOptionalAction,
        default=True,
        help="Populate missing/stale issue row metadata such as ItemType, repos, Workstream, ActivePR, and lifecycle fields.",
    )
    parser.add_argument(
        "--issue",
        action="append",
        default=[],
        help="Limit reconciliation to one issue. Repeatable. Accepts NUMBER, #NUMBER, OWNER/REPO#NUMBER, or issue URL.",
    )
    parser.add_argument("--apply", action="store_true")
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Preview project status changes. This is the default unless --apply is passed.",
    )
    parser.add_argument("--summary")
    parser.add_argument(
        "--project-snapshot",
        help="Optional saved gh project item-list JSON snapshot. Dry-run can use item-list snapshots without Project v2 field metadata; apply requires field metadata.",
    )
    parser.add_argument(
        "--pr-lookup",
        action=argparse.BooleanOptionalAction,
        default=None,
        help="Search GitHub PRs while hydrating metadata. Defaults to off for snapshot dry-runs and on otherwise.",
    )
    return parser


def main() -> None:
    parser = build_parser()
    args = parser.parse_args()

    issue_filters = {issue_filter(raw) for raw in args.issue}
    pr_lookup = args.pr_lookup
    if pr_lookup is None:
        pr_lookup = not (args.project_snapshot and not args.apply)
    configs: dict[tuple[str, int], ProjectConfig] = {}
    decisions: list[ProjectDecision] = []
    for owner, project_number in project_targets(args.projects_file, args.owner, args.project_number):
        config = (
            snapshot_project_config(args.project_snapshot, owner, project_number, allow_inferred=not args.apply)
            if args.project_snapshot
            else project_config(owner, project_number)
        )
        configs[(owner, project_number)] = config
        raw_items = (
            common.project_snapshot_items(args.project_snapshot, owner, project_number)
            if args.project_snapshot
            else project_items(owner, project_number, args.limit)
        )
        if args.project_snapshot and len(raw_items) >= args.limit:
            raw_items = raw_items[: args.limit]
        items = [item for item in raw_items if item_matches_issue_filters(item, issue_filters)]
        decisions.extend(
            decide(
                owner,
                project_number,
                config,
                items,
                hydrate_metadata=args.hydrate_metadata,
                pr_lookup=pr_lookup,
            )
        )
    if args.summary:
        write_summary(args.summary, decisions)
    for decision in decisions:
        ref = f"{decision.repo}#{decision.number}"
        children = ", ".join(decision.child_refs[:8])
        print(
            f"{'APPLY' if args.apply else 'DRY-RUN'} PROJECT-RECONCILE {ref}: "
            f"{decision.status_from} -> {decision.status_to}: {', '.join(decision.reasons)}"
            + (f" ({children})" if children else ""),
            flush=True,
        )
        if args.apply:
            apply_decision(decision, configs[(decision.owner, decision.project_number)])


if __name__ == "__main__":
    main()
