#!/usr/bin/env python3
"""Build one run-scoped summary for an e2e local-agent cycle."""

from __future__ import annotations

import argparse
import json
import os
from datetime import datetime, timezone
from pathlib import Path
from urllib import request

import atlas_agent_common as common


def read_json(path: Path) -> dict:
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return {}


def load_build_results(chain_dir: Path, cycle: int) -> list[dict[str, str]]:
    path = chain_dir / f"build-cycle-{cycle}.results.tsv"
    rows: list[dict[str, str]] = []
    if not path.exists():
        return rows
    for raw in path.read_text(encoding="utf-8").splitlines():
        status, repo, log_file = (raw.split("\t") + ["", "", ""])[:3]
        rows.append({"status": status, "repo": repo, "log_file": log_file})
    return rows


def load_triage_blockers(chain_dir: Path, cycle: int) -> list[dict]:
    blockers: list[dict] = []
    seen: set[str] = set()
    for path in sorted(chain_dir.glob(f"local-needs-human-summary-*-cycle-{cycle}.json")):
        data = read_json(path)
        records = data.get("records") or data.get("issues") or data.get("items") or []
        if isinstance(records, dict):
            records = list(records.values())
        for item in records if isinstance(records, list) else []:
            if not isinstance(item, dict):
                continue
            key = str(item.get("dedupe_key") or item.get("url") or f"{item.get('repo')}#{item.get('number')}")
            if key in seen:
                continue
            seen.add(key)
            blockers.append(item)
    return blockers


def action_instruction(item: dict) -> str:
    reasons = [str(reason) for reason in item.get("reasons") or []]
    reason_text = " ".join(reasons).lower()
    label = str(item.get("label") or "")
    action = str(item.get("action") or "")
    repo = item.get("repo") or "unknown repo"
    number = item.get("number") or item.get("entity_id") or "?"

    if label == "agent:manual-validation-required" or "manual or deployed validation required" in reason_text:
        return (
            f"Open {repo}#{number}, run the manual/deployed validation named by the PR or project gate, "
            "record the evidence in a PR comment, then add `agent:manual-validation-approved`."
        )
    if label == "agent:local-validation-required" or "local validation required" in reason_text:
        return (
            f"Open {repo}#{number}; either configure `local-validation.json` for this repo/path or "
            "run the local validation manually and add the passing evidence."
        )
    if label == "agent:semantic-review-required" or "semantic review required" in reason_text:
        return f"Run `./atlas-agent-semantic-review {repo}#{number} --apply`, address any findings, then rerun review."
    if label == "agent:human-action-required" or "failed workflow classified: secret/config" in reason_text:
        return (
            f"Open {repo}#{number}, fix the missing secret/configuration blocker named in the failed-workflow review, "
            "then rerun the failed GitHub workflow."
        )
    if "failed workflow classified: infra/env" in reason_text:
        return (
            f"Open {repo}#{number}, fix the Azure/environment blocker named in the failed-workflow review, "
            "then rerun the failed GitHub workflow."
        )
    if "failed workflow classified: human-action" in reason_text:
        return (
            f"Open {repo}#{number}, complete the required GitHub/Azure approval or manual action, "
            "then rerun the failed workflow."
        )
    if "failed workflow classified: dependency-blocked" in reason_text:
        return (
            f"Open {repo}#{number}, wait for or unblock the external dependency named in the failed-workflow review, "
            "then rerun the failed workflow."
        )
    if "failed workflow classified: deployed-validation" in reason_text:
        return f"Run `./atlas-agent-deployed-validate {repo}#{number} --apply`, then rerun review."
    if "ci review required" in reason_text:
        return f"Run `./atlas-agent-review --apply` so the failed workflow is reviewed on {repo}#{number} before any repair agent runs."
    if label == "agent:needs-repair":
        if "semantic review failed" in reason_text:
            return f"Open {repo}#{number}, address the semantic review blocking findings, run `./atlas-agent-semantic-review {repo}#{number} --apply`, then rerun review."
        if "no checks reported" in reason_text:
            return (
                f"Open {repo}#{number}; make GitHub publish a check for this PR, or configure the repo's "
                "local/docs-only validation path so review can approve it without CI."
            )
        return f"Open {repo}#{number}, inspect the review reasons, and repair the PR before rerunning automation."
    if label == "agent:overlap-queued" or "queued behind overlapping pr" in reason_text:
        return (
            f"Open {repo}#{number}; merge or close the earlier overlapping PR named in the review reason, "
            "then rerun the unattended cycle."
        )
    if "merge state is blocked" in reason_text:
        return f"Open {repo}#{number}, resolve branch protection, conflicts, or required status checks blocking merge."
    if "no checks reported" in reason_text:
        return (
            f"Open {repo}#{number}; trigger or add the expected GitHub check, or explicitly configure "
            "local/docs-only validation for this repo."
        )
    if action == "blocked":
        return f"Open {repo}#{number}, clear the listed finalizer blockers, then rerun automation."
    return f"Inspect {repo}#{number} and complete the human action described in the linked issue or PR."


def failed_workflow_link(item: dict) -> str:
    ci_review = item.get("ci_review") or {}
    runs = ci_review.get("runs") or []
    for run in runs:
        url = str(run.get("url") or "")
        name = str(run.get("name") or "failed workflow")
        if url.startswith("https://"):
            return f"[{name}]({url})"
    return ""


def item_url(item: dict) -> str:
    for key in ("url", "pr_url", "issue_url", "dashboard_url"):
        value = str(item.get(key) or "")
        if value.startswith("https://"):
            return value
    return ""


def item_title(item: dict) -> str:
    repo = item.get("repo") or "unknown repo"
    number = item.get("number") or item.get("entity_id") or "?"
    title = f"{repo}#{number}"
    url = item_url(item)
    return f"[{title}]({url})" if url else title


def urgent_items(summary: dict) -> list[dict]:
    items: list[dict] = []
    for row in summary["build"]["results"]:
        if row.get("status") == "failed":
            items.append(
                {
                    "kind": "dispatch-failure",
                    "title": row.get("repo"),
                    "instruction": f"Inspect `{row.get('log_file')}` and fix the worker/runtime failure, then rerun automation.",
                }
            )
    for item in summary["triage"]["blockers"]:
        items.append(
            {
                "kind": "needs-human",
                "title": item_title(item),
                "instruction": action_instruction(item),
            }
        )
    for item in summary["review"]["blocked"]:
        instruction = action_instruction(item)
        workflow = failed_workflow_link(item)
        if workflow:
            instruction = f"{instruction} Failed workflow: {workflow}."
        items.append(
            {
                "kind": "review-blocked",
                "title": item_title(item),
                "instruction": instruction,
            }
        )
    for item in summary.get("automation", {}).get("failed_stages", []):
        target = item.get("target") or item.get("stage") or "automation"
        items.append(
            {
                "kind": f"{item.get('stage')}-failed",
                "title": str(target),
                "instruction": f"Inspect `{item.get('log_file')}` for the {item.get('stage')} failure on {target}, then rerun automation.",
            }
        )
    for item in summary["finalizer"]["blocked"]:
        items.append(
            {
                "kind": "finalizer-blocked",
                "title": item_title(item),
                "instruction": action_instruction(item),
            }
        )
    deduped: list[dict] = []
    seen: set[tuple[str, str]] = set()
    for item in items:
        key = (str(item.get("title")), str(item.get("instruction")))
        if key in seen:
            continue
        seen.add(key)
        deduped.append(item)
    return deduped[:12]


def load_finalizer(chain_dir: Path, cycle: int) -> list[dict]:
    data = read_json(chain_dir / f"finalize-cycle-{cycle}.json")
    decisions = data.get("decisions") or []
    return decisions if isinstance(decisions, list) else []


def load_review(chain_dir: Path, cycle: int) -> list[dict]:
    data = read_json(chain_dir / f"review-cycle-{cycle}.json")
    decisions = data.get("decisions") or []
    return decisions if isinstance(decisions, list) else []


def load_dependency_promotions(chain_dir: Path, cycle: int) -> list[dict]:
    data = read_json(chain_dir / f"dependency-promote-cycle-{cycle}.json")
    decisions = data.get("decisions") or []
    return decisions if isinstance(decisions, list) else []


def load_stage_failures(chain_dir: Path, cycle: int) -> list[dict]:
    failures: list[dict] = []
    for stage in ("local-validate", "semantic-review", "deployed-validate", "repair"):
        data = read_json(chain_dir / f"{stage}-cycle-{cycle}.results.json")
        for result in data.get("results") or []:
            if result.get("status") == "ok":
                continue
            failures.append(
                {
                    "stage": stage,
                    "target": result.get("name") or stage,
                    "log_file": result.get("log_file"),
                    "returncode": result.get("returncode"),
                }
            )
    return failures


def summarize(chain_dir: Path, cycle: int) -> dict:
    build_results = load_build_results(chain_dir, cycle)
    triage_blockers = load_triage_blockers(chain_dir, cycle)
    dependency_promotions = load_dependency_promotions(chain_dir, cycle)
    review = load_review(chain_dir, cycle)
    finalizer = load_finalizer(chain_dir, cycle)
    stage_failures = load_stage_failures(chain_dir, cycle)
    review_counts: dict[str, int] = {}
    for item in review:
        label = str(item.get("label") or "unknown")
        review_counts[label] = review_counts.get(label, 0) + 1
    finalizer_counts: dict[str, int] = {}
    for item in finalizer:
        action = str(item.get("action") or "unknown")
        finalizer_counts[action] = finalizer_counts.get(action, 0) + 1
    promotion_counts: dict[str, int] = {}
    for item in dependency_promotions:
        action = str(item.get("action") or "unknown")
        promotion_counts[action] = promotion_counts.get(action, 0) + 1
    return {
        "generated_at": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
        "chain_id": chain_dir.name.replace("e2e-chain-", ""),
        "chain_dir": str(chain_dir),
        "cycle": cycle,
        "build": {
            "ok": sum(1 for row in build_results if row.get("status") == "ok"),
            "failed": sum(1 for row in build_results if row.get("status") == "failed"),
            "results": build_results,
        },
        "triage": {
            "blocker_count": len(triage_blockers),
            "blockers": triage_blockers[:25],
        },
        "dependency_promote": {
            "counts": promotion_counts,
            "promoted": [item for item in dependency_promotions if item.get("action") == "promote"][:25],
            "blocked": [item for item in dependency_promotions if item.get("action") == "blocked"][:25],
        },
        "review": {
            "counts": review_counts,
            "blocked": [item for item in review if item.get("label") != "agent:review-approved"][:25],
            "approved": [item for item in review if item.get("label") == "agent:review-approved"][:25],
        },
        "automation": {
            "failed_stages": stage_failures[:25],
        },
        "finalizer": {
            "counts": finalizer_counts,
            "blocked": [item for item in finalizer if item.get("action") == "blocked"][:25],
            "actionable": [item for item in finalizer if item.get("action") != "blocked"][:25],
        },
    }


def message_card(summary: dict) -> dict:
    lines = [
        f"**Chain:** `{summary['chain_id']}` cycle `{summary['cycle']}`",
        f"**Build:** {summary['build']['ok']} ok, {summary['build']['failed']} failed",
        f"**Triage blockers:** {summary['triage']['blocker_count']}",
        f"**Dependency promote:** {summary.get('dependency_promote', {}).get('counts', {})}",
        f"**Review:** {summary.get('review', {}).get('counts', {})}",
        f"**Automation stage failures:** {len(summary.get('automation', {}).get('failed_stages', []))}",
        f"**Finalizer:** {summary['finalizer']['counts']}",
        f"**State:** `{summary['chain_dir']}`",
    ]
    blocked = summary["finalizer"]["blocked"][:8]
    if blocked:
        lines.append("")
        lines.append("**Top blocked PRs:**")
        for item in blocked:
            reason = ", ".join((item.get("reasons") or [])[:2])
            lines.append(f"- {item.get('repo')}#{item.get('number')}: {reason}")
    failures = [row for row in summary["build"]["results"] if row.get("status") == "failed"][:8]
    if failures:
        lines.append("")
        lines.append("**Build failures:**")
        for row in failures:
            lines.append(f"- {row.get('repo')}: `{row.get('log_file')}`")
    theme = "D13438" if summary["build"]["failed"] or blocked else "107C10"
    return {
        "@type": "MessageCard",
        "@context": "https://schema.org/extensions",
        "themeColor": theme,
        "summary": f"Local automation cycle {summary['chain_id']}:{summary['cycle']}",
        "title": "Local automation cycle summary",
        "text": "\n\n".join(lines),
    }


def urgent_message_card(summary: dict) -> dict:
    items = urgent_items(summary)
    lines = [
        f"**Chain:** `{summary['chain_id']}` cycle `{summary['cycle']}`",
        f"**State:** `{summary['chain_dir']}`",
        "",
        "**Automation is blocked and needs human action. Do these in order:**",
    ]
    for idx, item in enumerate(items, start=1):
        lines.append(f"{idx}. **{item.get('title')}** - {item.get('instruction')}")
    return {
        "@type": "MessageCard",
        "@context": "https://schema.org/extensions",
        "themeColor": "D13438",
        "summary": f"Local automation blocked {summary['chain_id']}:{summary['cycle']}",
        "title": "URGENT: Local automation blocked",
        "text": "\n\n".join(lines),
    }


def post_teams(payload: dict, webhook: str) -> int:
    data = json.dumps(payload).encode("utf-8")
    req = request.Request(webhook, data=data, headers={"Content-Type": "application/json"}, method="POST")
    with request.urlopen(req, timeout=30) as response:
        return response.status


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--chain-dir", required=True)
    parser.add_argument("--cycle", required=True, type=int)
    parser.add_argument("--output", required=True)
    parser.add_argument("--post-teams", action="store_true")
    args = parser.parse_args()

    summary = summarize(Path(args.chain_dir), args.cycle)
    common.write_json(Path(args.output), summary)
    if args.post_teams:
        cfg = common.read_config()
        webhook = os.environ.get("TEAMS_DAILY_DIGEST_WEBHOOK_URL") or cfg.get("TEAMS_DAILY_DIGEST_WEBHOOK_URL")
        if webhook:
            status = post_teams(message_card(summary), webhook)
            print(f"Teams cycle summary accepted with HTTP {status}.", flush=True)
        else:
            print("No Teams cycle-summary webhook configured.", flush=True)
        urgent = urgent_items(summary)
        urgent_webhook = os.environ.get("TEAMS_URGENT_WEBHOOK_URL") or cfg.get("TEAMS_URGENT_WEBHOOK_URL")
        if urgent and urgent_webhook:
            status = post_teams(urgent_message_card(summary), urgent_webhook)
            print(f"Teams urgent blocker notification accepted with HTTP {status}.", flush=True)
        elif urgent:
            print("Automation is blocked, but no TEAMS_URGENT_WEBHOOK_URL is configured.", flush=True)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
