#!/usr/bin/env python3
"""Classify and decompose oversized GitHub issues before local-agent dispatch."""

from __future__ import annotations

import argparse
import json
import os
import re
import shutil
from pathlib import Path
from typing import Any

import atlas_agent_common as common


ONE_POINT_LABEL = "agent:one-point"
DECOMPOSITION_REQUIRED_LABEL = "agent:decomposition-required"
DECOMPOSED_LABEL = "agent:decomposed"
CHILD_INHERITED_LABEL_PREFIXES = ("area:", "owner:", "repo:", "tier:", "workstream:", "priority:")
CHILD_INHERITED_LABELS = {"type:story", "type:spike", "type:task"}


def target_repos(path: str | None) -> list[str]:
    repo_file = Path(path) if path else common.RUNTIME_DIR / "repos.txt"
    repos: list[str] = []
    for raw in repo_file.read_text(encoding="utf-8").splitlines():
        line = raw.split("#", 1)[0].strip()
        if line:
            repos.append(line)
    return repos


def issue_points(issue: dict[str, Any]) -> int | None:
    return common.issue_points(issue)


def candidate_issues(repo: str, label: str, limit: int) -> list[dict[str, Any]]:
    return common.gh_json_or_none(
        [
            "issue",
            "list",
            "--repo",
            repo,
            "--state",
            "open",
            "--label",
            label,
            "--limit",
            str(limit),
            "--json",
            "number,title,body,labels,author,url",
        ],
        retries=2,
    ) or []


def candidate_issues_for_labels(repo: str, labels: list[str], limit: int) -> list[dict[str, Any]]:
    issues: list[dict[str, Any]] = []
    seen: set[int] = set()
    for label in labels:
        if len(issues) >= limit:
            break
        for issue in candidate_issues(repo, label, max(limit - len(issues), 1)):
            number = int(issue.get("number") or 0)
            if number in seen:
                continue
            seen.add(number)
            issues.append(issue)
            if len(issues) >= limit:
                break
    return issues


def project_issue_keys(projects_file: str | None) -> set[tuple[str, int]] | None:
    if not projects_file:
        return None
    keys: set[tuple[str, int]] = set()
    for owner, project_number in project_targets(projects_file):
        for item in common.project_items(owner, project_number):
            content = item.get("content") or {}
            repo = content.get("repository")
            number = content.get("number")
            if repo and number:
                keys.add((str(repo), int(number)))
    return keys


def filter_project_issues(
    repo: str,
    issues: list[dict[str, Any]],
    allowed_issue_keys: set[tuple[str, int]] | None,
) -> list[dict[str, Any]]:
    if allowed_issue_keys is None:
        return issues
    return [
        issue
        for issue in issues
        if (repo, int(issue.get("number") or 0)) in allowed_issue_keys
    ]


def issue_ref_parts(raw: str, default_repo: str | None) -> tuple[str, int]:
    text = str(raw).strip()
    url_match = re.match(r"^https://github\.com/(?P<repo>[^/]+/[^/]+)/issues/(?P<number>\d+)(?:\b|$)", text)
    if url_match:
        return url_match.group("repo"), int(url_match.group("number"))
    if text.startswith("#"):
        text = text[1:]
    ref_match = re.match(r"^(?:(?P<repo>[^#\s]+/[^#\s]+)#)?(?P<number>\d+)$", text)
    if not ref_match:
        raise ValueError(f"Issue reference must be NUMBER, #NUMBER, OWNER/REPO#NUMBER, or a GitHub issue URL: {raw}")
    repo = ref_match.group("repo") or default_repo
    if not repo:
        raise ValueError(f"Unqualified issue reference requires exactly one repo in --repos-file: {raw}")
    return repo, int(ref_match.group("number"))


def fetch_issue(repo: str, number: int) -> dict[str, Any] | None:
    return common.gh_json_or_none(
        [
            "issue",
            "view",
            str(number),
            "--repo",
            repo,
            "--json",
            "number,title,body,labels,author,url",
        ],
        retries=2,
    )


def candidate_issues_for_explicit_refs(
    repo: str, refs: list[str], limit: int, default_repo: str | None
) -> list[dict[str, Any]]:
    issues: list[dict[str, Any]] = []
    seen: set[int] = set()
    for raw in refs:
        if len(issues) >= limit:
            break
        ref_repo, number = issue_ref_parts(raw, default_repo)
        if ref_repo != repo or number in seen:
            continue
        issue = fetch_issue(repo, number)
        if not issue:
            continue
        seen.add(number)
        issues.append(issue)
    return issues


def classify_issue(repo: str, issue: dict[str, Any]) -> dict[str, Any]:
    labels = common.label_names(issue)
    point_values = common.issue_point_values(issue)
    points = issue_points(issue)
    action = "needs-points"
    reason = ""
    if DECOMPOSED_LABEL in labels:
        action = "already-decomposed"
    elif len(point_values) > 1:
        action = "decompose" if any(value > 1 for value in point_values) else "needs-points"
        reason = "conflicting point metadata"
    elif points and points > 1:
        action = "decompose"
    elif ONE_POINT_LABEL in labels or points == 1:
        action = "mark-one-point"
    record = {
        "repo": repo,
        "number": issue.get("number"),
        "title": issue.get("title"),
        "url": issue.get("url"),
        "points": points,
        "action": action,
    }
    if reason:
        record["reason"] = reason
        record["point_values"] = point_values
    return record


