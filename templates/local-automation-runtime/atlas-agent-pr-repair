#!/usr/bin/env python3
"""Repair an existing PR branch with local Codex using failed-check evidence."""

from __future__ import annotations

import argparse
import json
import os
import pathlib
import re
import shutil

import atlas_agent_common as common


def pr_json(repo: str, number: int) -> dict:
    return common.gh_json(
        [
            "pr",
            "view",
            str(number),
            "--repo",
            repo,
            "--json",
            "number,title,body,author,url,state,isDraft,headRefName,baseRefName,headRefOid,"
            "mergeStateStatus,mergeable,reviewDecision,latestReviews,statusCheckRollup,labels,"
            "headRepository,headRepositoryOwner,comments,reviews",
        ]
    )


def collect_checks(repo: str, number: int, job_dir: pathlib.Path) -> str:
    proc = common.run(
        ["gh", "pr", "checks", str(number), "--repo", repo, "--json", "name,state,bucket,link,description"],
        check=False,
    )
    (job_dir / "pr-checks.json").write_text(proc.stdout or "[]", encoding="utf-8")
    return proc.stdout or ""


def collect_failed_run_log(repo: str, branch: str, job_dir: pathlib.Path) -> str:
    runs = common.gh_json(
        [
            "run",
            "list",
            "--repo",
            repo,
            "--branch",
            branch,
            "--limit",
            "5",
            "--json",
            "databaseId,status,conclusion,name,displayTitle,url,createdAt,updatedAt",
        ]
    )
    common.write_json(job_dir / "runs.json", runs)
    failed = [
        item
        for item in runs or []
        if item.get("conclusion") in {"failure", "timed_out", "cancelled", "action_required"}
    ]
    if not failed:
        return ""
    run_id = str(failed[0]["databaseId"])
    proc = common.run(["gh", "run", "view", run_id, "--repo", repo, "--log-failed"], check=False)
    log = proc.stdout or ""
    (job_dir / f"run-{run_id}-failed.log").write_text(log, encoding="utf-8", errors="replace")
    return log[-20000:]


def collect_review_comments(repo: str, number: int, job_dir: pathlib.Path) -> str:
    proc = common.run(["gh", "api", f"repos/{repo}/pulls/{number}/comments", "--paginate"], check=False)
    output = proc.stdout or "[]"
    (job_dir / "review-comments.json").write_text(output, encoding="utf-8")
    return output


def current_head_semantic_review(pr: dict) -> str:
    head_oid = str(pr.get("headRefOid") or "").strip()
    if not head_oid:
        return ""
    for comment in reversed(pr.get("comments") or []):
        body = str(comment.get("body") or "")
        if "<!-- atlas-agent-semantic-review -->" not in body:
            continue
        if not re.search(rf"(?im)^\s*Head:\s*`?{re.escape(head_oid)}`?\s*$", body):
            continue
        return body
    return ""


def has_merge_conflict(pr: dict) -> bool:
    merge_state = str(pr.get("mergeStateStatus") or "").upper()
    mergeable = str(pr.get("mergeable") or "").upper()
    return merge_state in {"DIRTY", "BLOCKED"} or mergeable == "CONFLICTING"


def requested_change_reviews(pr: dict) -> list[dict]:
    requested: list[dict] = []
    for review in pr.get("latestReviews") or []:
        state = str(review.get("state") or "").upper()
        if state in {"CHANGES_REQUESTED", "REQUEST_CHANGES"}:
            requested.append(review)
    return requested


def head_repository_full_name(pr: dict) -> str:
    repo = pr.get("headRepository") or {}
    if isinstance(repo, dict):
        for key in ("nameWithOwner", "nameWithowner"):
            value = repo.get(key)
            if value:
                return str(value)
        owner = (pr.get("headRepositoryOwner") or {}).get("login")
        name = repo.get("name")
        if owner and name:
            return f"{owner}/{name}"
    return ""


def build_prompt(
    pr: dict,
    checks: str,
    failed_log: str,
    review_comments: str = "[]",
    semantic_review: str = "",
) -> str:
    return f"""You are repairing GitHub PR #{pr["number"]}.

PR: {pr["url"]}
Title: {pr.get("title", "")}
Base branch: {pr.get("baseRefName", "")}
Head branch: {pr.get("headRefName", "")}

PR body:
{pr.get("body") or ""}

Recent comments:
{json.dumps(pr.get("comments", []), indent=2)}

Reviews:
{json.dumps(pr.get("reviews", []), indent=2)}

Requested-change reviews:
{json.dumps(requested_change_reviews(pr), indent=2)}

Inline review comments:
{review_comments}

Current-head semantic review:
{semantic_review or "No current-head semantic review was found."}

Check summary:
{checks}

Failed workflow log excerpt:
{failed_log}

Instructions:
- Repair this PR branch only.
- If the worktree contains merge conflicts with the base branch, resolve them while preserving the PR intent.
- Keep the change focused on the failing checks, semantic review findings, requested changes, or inline review comments.
- Do not change secrets, credentials, deployment settings, or unrelated workflows.
- Run the most relevant local tests you can.
- Leave a concise final summary with tests run.
"""


def verify_repairable_pr(repo: str, pr: dict) -> None:
    if str(pr.get("state") or "") != "OPEN":
        raise SystemExit(f"Refusing to repair non-open PR state: {pr.get('state')}")
    head_repo = head_repository_full_name(pr)
    if head_repo and head_repo != repo:
        raise SystemExit(f"Refusing cross-repo PR repair: head repository is {head_repo}, base repository is {repo}.")
    labels = common.label_names(pr)
    has_repair_route = "agent:needs-repair" in labels
    if (
        pr.get("isDraft")
        and not has_repair_route
        and not has_merge_conflict(pr)
        and not current_head_semantic_review(pr)
        and not requested_change_reviews(pr)
    ):
        checks = pr.get("statusCheckRollup") or []
        failed_checks = [
            check
            for check in checks
            if str(check.get("conclusion") or "").upper() not in {"", "SUCCESS", "NEUTRAL", "SKIPPED"}
        ]
        if not failed_checks:
            raise SystemExit("Refusing to repair draft/no-evidence PR; route through validation/finalizer first.")


def codex_timeout_seconds() -> int:
    cfg = common.read_config()
    raw = (
        os.environ.get("AGENT_CODEX_REPAIR_TIMEOUT_SECONDS")
        or cfg.get("AGENT_CODEX_REPAIR_TIMEOUT_SECONDS")
        or os.environ.get("AGENT_CODEX_TIMEOUT_SECONDS")
        or cfg.get("AGENT_CODEX_TIMEOUT_SECONDS")
        or "1800"
    )
    try:
        seconds = int(str(raw).strip().strip('"'))
    except ValueError:
        return 1800
    return max(seconds, 1)


def with_timeout(cmd: list[str]) -> list[str]:
    if shutil.which("timeout"):
        return ["timeout", str(codex_timeout_seconds()), *cmd]
    return cmd


def run_codex(repo_path: pathlib.Path, job_dir: pathlib.Path, prompt: str) -> str:
    prompt_path = job_dir / "prompt.md"
    prompt_path.write_text(prompt, encoding="utf-8")
    run_home = common.codex_home_copy(job_dir)
    profile_args = common.codex_profile_shell_args("repair")
    profile_segment = f"{profile_args} " if profile_args else ""
    shell_command = (
        f"cd /work && codex exec {profile_segment}"
        "--ephemeral --skip-git-repo-check --dangerously-bypass-approvals-and-sandbox - < /job/prompt.md"
    )

    def run_local_codex():
        if not shutil.which("codex"):
            return None
        env = os.environ.copy()
        env["CODEX_HOME"] = str(run_home)
        return common.run(
            with_timeout([
                "bash",
                "-lc",
                f"codex exec {profile_segment}--ephemeral --skip-git-repo-check --dangerously-bypass-approvals-and-sandbox - < {prompt_path}",
            ]),
            cwd=repo_path,
            check=False,
            env=env,
        )

    try:
        cmd = [
            *common.podman_cmd(),
            "run",
            "--rm",
            *common.podman_userns_args(),
            "--network=slirp4netns",
            "-v",
            f"{run_home}:/home/agent/.codex:Z",
            "-v",
            f"{repo_path}:/work:Z",
            "-v",
            f"{job_dir}:/job:Z",
            common.codex_image(),
            "bash",
            "-lc",
            shell_command,
        ]
        proc = common.run(with_timeout(cmd), cwd=repo_path, check=False)
        if proc.returncode != 0 and "podman: command not found" in (proc.stdout or "").lower():
            fallback = run_local_codex()
            if fallback is not None:
                proc = fallback
    except RuntimeError:
        fallback = run_local_codex()
        if fallback is None:
            raise
        proc = fallback
    finally:
        shutil.rmtree(run_home, ignore_errors=True)
    (job_dir / "codex.log").write_text(proc.stdout or "", encoding="utf-8", errors="replace")
    if proc.returncode != 0:
        raise RuntimeError(f"Codex repair failed with status {proc.returncode}; see {job_dir}/codex.log")
    return proc.stdout or ""


def reconcile_base_if_needed(pr: dict, repo_path: pathlib.Path, repair_path: pathlib.Path, job_dir: pathlib.Path) -> None:
    if not has_merge_conflict(pr):
        return
    base = str(pr.get("baseRefName") or "").strip()
    if not base:
        raise SystemExit("Refusing merge-conflict repair without a base branch.")
    common.run(["git", "fetch", "origin", base], cwd=repo_path)
    proc = common.run(["git", "merge", "--no-edit", f"origin/{base}"], cwd=repair_path, check=False)
    (job_dir / "base-reconcile.log").write_text(proc.stdout or "", encoding="utf-8", errors="replace")
    if proc.returncode == 0:
        return
    unresolved = common.run(["git", "diff", "--name-only", "--diff-filter=U"], cwd=repair_path).stdout.strip()
    if not unresolved:
        raise RuntimeError(f"Base reconciliation failed without merge conflicts; see {job_dir}/base-reconcile.log")
    (job_dir / "merge-conflicts.txt").write_text(unresolved + "\n", encoding="utf-8")


def repair(args: argparse.Namespace) -> None:
    repo, number = common.pr_ref_parts(args.pr)
    pr = pr_json(repo, number)
    verify_repairable_pr(repo, pr)

    job_dir = common.jobs_dir() / f"pr-{number}-repair-{common.now_id()}"
    job_dir.mkdir(parents=True, exist_ok=True)
    common.write_json(job_dir / "pr.json", pr)

    repo_path = common.ensure_repo(repo)
    head = pr["headRefName"]
    repair_path = common.jobs_dir() / "checkouts" / common.safe_repo_name(repo) / f"pr-{number}-repair-{common.now_id()}"
    repair_path.parent.mkdir(parents=True, exist_ok=True)
    common.run(["git", "worktree", "add", "--detach", str(repair_path), f"origin/{head}"], cwd=repo_path)
    checked_out = common.run(["git", "rev-parse", "HEAD"], cwd=repair_path).stdout.strip()
    expected = str(pr.get("headRefOid") or "").strip()
    if expected and checked_out != expected:
        raise SystemExit(f"Refusing to repair wrong checkout: HEAD is {checked_out}, PR head is {expected}")
    original_head = checked_out
    status = common.run(["git", "status", "--short"], cwd=repair_path).stdout.strip()
    if status:
        raise SystemExit(f"Refusing to repair with dirty worktree:\n{status}")
    common.ensure_git_identity(repair_path)
    reconcile_base_if_needed(pr, repo_path, repair_path, job_dir)

    checks = collect_checks(repo, number, job_dir)
    failed_log = collect_failed_run_log(repo, head, job_dir)
    review_comments = collect_review_comments(repo, number, job_dir)
    run_codex(repair_path, job_dir, build_prompt(pr, checks, failed_log, review_comments, current_head_semantic_review(pr)))

    status = common.run(["git", "status", "--short"], cwd=repair_path).stdout
    current_head = common.run(["git", "rev-parse", "HEAD"], cwd=repair_path).stdout.strip()
    diff_stat = common.run(["git", "diff", "--stat"], cwd=repair_path).stdout
    (job_dir / "status.txt").write_text(status, encoding="utf-8")
    (job_dir / "diff.stat.txt").write_text(diff_stat, encoding="utf-8")
    (job_dir / "diff.patch").write_text(common.run(["git", "diff"], cwd=repair_path).stdout, encoding="utf-8")

    if not status.strip() and current_head == original_head:
        common.run(
            [
                "gh",
                "pr",
                "comment",
                str(number),
                "--repo",
                repo,
                "--body",
                f"Local Codex PR repair ran, but produced no file changes. Artifacts: `{job_dir}`",
            ],
            check=False,
        )
        return

    if args.dry_run:
        print(f"Dry run complete. Artifacts: {job_dir}")
        print(diff_stat)
        return

    if status.strip():
        unresolved = common.run(["git", "diff", "--name-only", "--diff-filter=U"], cwd=repair_path).stdout.strip()
        if unresolved:
            raise RuntimeError(f"Repair left unresolved merge conflicts:\n{unresolved}")
        common.run(["git", "add", "-A"], cwd=repair_path)
        common.run(["git", "commit", "-m", f"agent: repair PR #{number}"], cwd=repair_path)
    common.run(["git", "push", "origin", f"HEAD:{head}"], cwd=repair_path)
    common.run(
        [
            "gh",
            "pr",
            "comment",
            str(number),
            "--repo",
            repo,
            "--body",
            f"Local Codex pushed a repair commit for PR #{number}.\n\nArtifacts: `{job_dir}`",
        ],
        check=False,
    )
    print(f"Repair pushed. Artifacts: {job_dir}")


def main() -> None:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("pr", help="OWNER/REPO#PR_NUMBER")
    parser.add_argument("--dry-run", action="store_true")
    args = parser.parse_args()
    repair(args)


if __name__ == "__main__":
    main()
