def no_checks_expected_for_paths(repo: str, labels: set[str], files: list[str], config_path: str | None) -> tuple[bool, str]:
    policy = common.no_checks_policy_for_repo(repo, Path(config_path) if config_path else None)
    if not policy:
        return False, "no no-checks policy configured"
    required_label = str(policy.get("require_label") or "").strip()
    if required_label and required_label not in labels:
        return False, f"no-checks policy label missing: {required_label}"
    allowed = [str(pattern).strip() for pattern in policy.get("allow_if_paths") or [] if str(pattern).strip()]
    if not allowed:
        return False, "no-checks policy has no allowed paths"
    if not files:
        return False, "no changed files reported for no-checks policy"
    unmatched = [path for path in files if not any(fnmatch.fnmatch(path, pattern) for pattern in allowed)]
    if unmatched:
        return False, f"changed files outside no-checks policy: {', '.join(unmatched[:5])}"
    return True, "no checks expected by path policy"


def project_issue_keys(projects_file: str | None, project_snapshot: str | None = None) -> set[tuple[str, int]] | None:
    if project_snapshot:
        keys: set[tuple[str, int]] = set()
        for item in common.project_snapshot_items(project_snapshot):
            content = item.get("content") or {}
            repo = content.get("repository")
            number = content.get("number")
            if repo and number:
                keys.add((str(repo), int(number)))
        return keys
    if not projects_file:
        return None
    keys: set[tuple[str, int]] = set()
    for owner, project_number in common.project_targets(projects_file):
        for item in common.project_items(owner, project_number):
            content = item.get("content") or {}
            repo = content.get("repository")
            number = content.get("number")
            if repo and number:
                keys.add((str(repo), int(number)))
    return keys


