def check_rollup_state(repo: str, pr: dict[str, Any], required_checks: list[str] | None = None) -> tuple[str, list[str]]:
    checks = pr.get("statusCheckRollup") or []
    if not checks:
        if required_checks:
            checks = common.commit_check_runs(repo, str(pr.get("headRefOid") or ""))
        if not checks:
            return "none", []
    observed: dict[str, tuple[str, str]] = {}
    pending: list[str] = []
    failed: list[str] = []
    passed: list[str] = []
    for check in checks:
        name = str(check.get("name") or check.get("context") or "unnamed")
        status = str(check.get("status") or "").upper()
        conclusion = str(check.get("conclusion") or "").upper()
        observed[name] = (status, conclusion)
        if status and status != "COMPLETED":
            pending.append(name)
        elif conclusion in {"SUCCESS", "NEUTRAL", "SKIPPED"}:
            passed.append(name)
        else:
            failed.append(name if not conclusion else f"{name}={conclusion}")
    required = required_checks or []
    missing_required = [name for name in required if name not in observed]
    if missing_required:
        for check in common.commit_check_runs(repo, str(pr.get("headRefOid") or "")):
            name = str(check.get("name") or check.get("context") or "unnamed")
            if name in observed:
                continue
            status = str(check.get("status") or "").upper()
            conclusion = str(check.get("conclusion") or "").upper()
            observed[name] = (status, conclusion)
        missing_required = [name for name in required if name not in observed]
    if missing_required:
        return "failed", [f"required check missing: {name}" for name in missing_required]
    required_failed: list[str] = []
    required_pending: list[str] = []
    for name in required:
        status, conclusion = observed[name]
        if status and status != "COMPLETED":
            required_pending.append(name)
        elif conclusion not in {"SUCCESS", "NEUTRAL", "SKIPPED"}:
            required_failed.append(name if not conclusion else f"{name}={conclusion}")
    if required_failed:
        return "failed", required_failed
    if required_pending:
        return "pending", required_pending
    if failed:
        return "failed", failed
    if pending:
        return "pending", pending
    return "passed", passed


def failed_check_summaries(pr: dict[str, Any]) -> list[str]:
    failed: list[str] = []
    for check in pr.get("statusCheckRollup") or []:
        name = str(check.get("name") or check.get("context") or "unnamed")
        status = str(check.get("status") or "").upper()
        conclusion = str(check.get("conclusion") or "").upper()
        if status and status != "COMPLETED":
            continue
        if conclusion and conclusion not in {"SUCCESS", "NEUTRAL", "SKIPPED"}:
            failed.append(name if not conclusion else f"{name}={conclusion}")
    return failed


def first_string(*values: Any) -> str:
    for value in values:
        if value:
            return str(value)
    return ""


def failed_pr_checks(repo: str, number: int, job_dir: Path) -> list[dict[str, Any]]:
    proc = common.run(
        ["gh", "pr", "checks", str(number), "--repo", repo, "--json", "name,state,bucket,link,description,workflow"],
        check=False,
    )
    raw = proc.stdout or "[]"
    (job_dir / "pr-checks.json").write_text(raw, encoding="utf-8")
    try:
        checks = json.loads(raw)
    except json.JSONDecodeError:
        return []
    failed: list[dict[str, Any]] = []
    for check in checks if isinstance(checks, list) else []:
        state = str(check.get("state") or "").upper()
        bucket = str(check.get("bucket") or "").lower()
        if bucket == "fail" or state in {"FAILURE", "FAILED", "ERROR", "CANCELLED", "TIMED_OUT", "ACTION_REQUIRED"}:
            failed.append(check)
    return failed


def failed_runs_for_pr(repo: str, pr: dict[str, Any], job_dir: Path, *, limit: int = 5) -> list[dict[str, Any]]:
    branch = str(pr.get("headRefName") or "")
    if not branch:
        return []
    runs = common.gh_json_or_none(
        [
            "run",
            "list",
            "--repo",
            repo,
            "--branch",
            branch,
            "--limit",
            str(limit),
            "--json",
            "databaseId,status,conclusion,name,displayTitle,url,createdAt,updatedAt,headSha,workflowName",
        ],
        retries=2,
    ) or []
    common.write_json(job_dir / "failed-workflow-runs.json", runs)
    head = str(pr.get("headRefOid") or "").strip()
    failed_conclusions = {"failure", "timed_out", "cancelled", "action_required", "startup_failure"}
    result: list[dict[str, Any]] = []
    for run in runs if isinstance(runs, list) else []:
        if head and str(run.get("headSha") or "") not in {"", head}:
            continue
        if str(run.get("conclusion") or "").lower() in failed_conclusions:
            result.append(run)
    return result


def failed_jobs_for_run(repo: str, run_id: int | str, job_dir: Path) -> list[dict[str, Any]]:
    payload = common.gh_json_or_none(
        ["run", "view", str(run_id), "--repo", repo, "--json", "jobs,url,name,conclusion,status,workflowName"],
        retries=2,
    ) or {}
    common.write_json(job_dir / f"run-{run_id}-jobs.json", payload)
    jobs = payload.get("jobs") or []
    if not isinstance(jobs, list):
        return []
    failed_conclusions = {"failure", "timed_out", "cancelled", "action_required", "startup_failure"}
    return [
        job
        for job in jobs
        if str(job.get("conclusion") or "").lower() in failed_conclusions
        or str(job.get("status") or "").lower() == "failure"
    ]


def failed_log_excerpt(repo: str, run_id: int | str, job_dir: Path) -> str:
    proc = common.run(["gh", "run", "view", str(run_id), "--repo", repo, "--log-failed"], check=False)
    log = proc.stdout or ""
    (job_dir / f"run-{run_id}-failed.log").write_text(log, encoding="utf-8", errors="replace")
    return trim_error_excerpt(log)


def trim_error_excerpt(log: str, *, max_lines: int = 28) -> str:
    if not log.strip():
        return ""
    lines = log.splitlines()
    markers = (
        "error:",
        "error ",
        "failed",
        "failure",
        "traceback",
        "exception",
        "assertionerror",
        "pytest",
        "npm err!",
        "secret",
        "environment",
        "approval",
        "unauthorized",
        "forbidden",
        "timeout",
    )
    lowered = [line.lower() for line in lines]
    indices = [idx for idx, line in enumerate(lowered) if any(marker in line for marker in markers)]
    if indices:
        start = max(indices[0] - 6, 0)
        end = min(start + max_lines, len(lines))
        return "\n".join(lines[start:end]).strip()
    return "\n".join(lines[-max_lines:]).strip()


def classify_failed_workflow(text: str, failed_checks: list[dict[str, Any]] | None = None) -> tuple[str, str]:
    lower = text.lower()
    check_text = " ".join(
        " ".join(str(check.get(key) or "") for key in ("name", "workflow", "description"))
        for check in failed_checks or []
    ).lower()
    combined = f"{lower}\n{check_text}"
    if any(token in combined for token in ("environment protection", "waiting for approval", "deployment approval", "review deployments")):
        return "human-action", "Workflow is blocked on a protected environment or manual deployment approval."
    if any(token in combined for token in ("secret", "secrets.", "not configured", "no such secret", "credential unavailable")):
        return "secret/config", "Workflow is blocked by a missing or invalid secret/configuration value."
    if any(token in combined for token in ("environment variable", "env var", "azure login", "az login", "subscription", "tenant", "resource group", "aadsts")):
        return "infra/env", "Workflow is blocked by provider/environment setup rather than a current-branch code change."
    if any(token in combined for token in ("deployed e2e", "deployed validation", "bootstrap dev tenant", "deploy dev", "functions deploy")):
        return "deployed-validation", "Workflow is part of deployed validation and should be rerun through the configured validation chain."
    if any(token in combined for token in ("could not resolve host", "temporary failure", "rate limit", "registry.npmjs.org", "pypi.org", "connection timed out")):
        return "dependency-blocked", "Workflow is blocked by an external dependency, network, or registry failure."
    if any(token in combined for token in ("pytest", "assertionerror", "test failed", "tests failed", "expected", "received")):
        return "test-repair", "Repository tests failed in a way that appears repairable on the current branch."
    if any(token in combined for token in ("typescript", "tsc", "eslint", "ruff", "mypy", "syntaxerror", "importerror", "modulenotfounderror", "compile")):
        return "code-repair", "Build, lint, typecheck, or import errors point to current-branch code."
    return "code-repair", "Failed workflow appears repairable by inspecting the current PR branch."


def ci_next_action(category: str, repo: str, number: int) -> str:
    if category in REPAIRABLE_CI_CATEGORIES:
        return f"Run `./atlas-agent-pr-repair {repo}#{number}` after this review marks the PR repairable."
    if category == "deployed-validation":
        return f"Run `./atlas-agent-deployed-validate {repo}#{number} --apply` or dispatch the configured deployed-validation workflow chain."
    if category == "secret/config":
        return "Add or fix the required GitHub/provider secret or repo environment value, then rerun the failed workflow."
    if category == "infra/env":
        return "Fix the provider/environment prerequisite, then rerun the failed workflow from GitHub Actions."
    if category == "dependency-blocked":
        return "Wait for or unblock the external dependency, then rerun the failed workflow from GitHub Actions."
    return "Complete the required human approval/action in GitHub or the configured provider, then rerun the failed workflow."


def fetch_failed_workflow_review(repo: str, pr: dict[str, Any], job_dir: Path) -> dict[str, Any] | None:
    if not failed_check_summaries(pr):
        return None
    number = int(pr["number"])
    failed_checks = failed_pr_checks(repo, number, job_dir)
    runs = failed_runs_for_pr(repo, pr, job_dir)
    run_reviews: list[dict[str, Any]] = []
    excerpt_parts: list[str] = []
    for run in runs[:3]:
        run_id = run.get("databaseId")
        if not run_id:
            continue
        jobs = failed_jobs_for_run(repo, run_id, job_dir)
        excerpt = failed_log_excerpt(repo, run_id, job_dir)
        if excerpt:
            excerpt_parts.append(excerpt)
        run_reviews.append(
            {
                "id": run_id,
                "name": first_string(run.get("workflowName"), run.get("name"), run.get("displayTitle")),
                "url": run.get("url"),
                "conclusion": run.get("conclusion"),
                "jobs": jobs[:8],
            }
        )
    evidence_text = "\n".join(excerpt_parts) or json.dumps(failed_checks, indent=2)
    category, summary = classify_failed_workflow(evidence_text, failed_checks)
    review = {
        "head": str(pr.get("headRefOid") or ""),
        "category": category,
        "root_cause": summary,
        "failed_checks": failed_checks[:8],
        "runs": run_reviews,
        "excerpt": trim_error_excerpt(evidence_text, max_lines=18),
        "next_action": ci_next_action(category, repo, number),
        "artifacts": str(job_dir),
    }
    common.write_json(job_dir / "failed-workflow-review.json", review)
    return review


def failed_workflow_comment_body(repo: str, number: int, review: dict[str, Any]) -> str:
    run_lines: list[str] = []
    for run in review.get("runs") or []:
        run_name = str(run.get("name") or f"run {run.get('id')}")
        run_url = str(run.get("url") or "")
        run_ref = f"[{run_name}]({run_url})" if run_url.startswith("https://") else run_name
        jobs = []
        for job in run.get("jobs") or []:
            job_name = str(job.get("name") or "failed job")
            job_url = str(job.get("url") or "")
            jobs.append(f"[{job_name}]({job_url})" if job_url.startswith("https://") else job_name)
        run_lines.append(f"- {run_ref}" + (f" jobs: {', '.join(jobs[:4])}" if jobs else ""))
    if not run_lines:
        for check in review.get("failed_checks") or []:
            name = str(check.get("name") or "failed check")
            link = str(check.get("link") or "")
            run_lines.append(f"- [{name}]({link})" if link.startswith("https://") else f"- {name}")
    excerpt = str(review.get("excerpt") or "").strip()
    excerpt_block = f"\n\nRelevant excerpt:\n```text\n{excerpt[:3000]}\n```" if excerpt else ""
    return (
        f"{FAILED_WORKFLOW_COMMENT_MARKER}\n"
        f"Head: `{review.get('head') or 'unknown'}`\n\n"
        "## Failed Workflow Review\n\n"
        "Failed workflow/jobs:\n"
        + ("\n".join(run_lines) if run_lines else "- Failed workflow details could not be fetched.")
        + "\n\n"
        f"Root cause: {review.get('root_cause')}\n\n"
        f"Classification: `{review.get('category')}`\n\n"
        f"Next action: {review.get('next_action')}\n\n"
        f"Artifacts: `{review.get('artifacts')}`"
        + excerpt_block
    )


def post_failed_workflow_review(repo: str, number: int, review: dict[str, Any]) -> None:
    body = failed_workflow_comment_body(repo, number, review)
    payload = common.gh_json_or_none(
        ["pr", "view", str(number), "--repo", repo, "--json", "comments"],
        retries=2,
    ) or {}
    head = str(review.get("head") or "")
    for comment in payload.get("comments") or []:
        existing = str(comment.get("body") or "")
        if FAILED_WORKFLOW_COMMENT_MARKER not in existing:
            continue
        if head and not re.search(rf"(?im)^\s*Head:\s*`?{re.escape(head)}`?\s*$", existing):
            continue
        comment_id = str(comment.get("id") or "")
        if not comment_id:
            return
        common.run(
            [
                "gh",
                "api",
                "graphql",
                "-f",
                "query=mutation($id: ID!, $body: String!) { updateIssueComment(input: { id: $id, body: $body }) { issueComment { id } } }",
                "-f",
                f"id={comment_id}",
                "-f",
                f"body={body}",
            ],
            check=False,
        )
        return
    common.run(["gh", "pr", "comment", str(number), "--repo", repo, "--body", body], check=False)


def local_validation_passed_for_head(pr: dict[str, Any]) -> bool:
    if LOCAL_VALIDATION_PASSED_LABEL not in common.label_names(pr):
        return False
    head_oid = str(pr.get("headRefOid") or "").strip()
    if not head_oid:
        return False
    for comment in reversed(pr.get("comments") or []):
        body = str(comment.get("body") or "")
        if LOCAL_VALIDATION_COMMENT_MARKER not in body:
            continue
        if not re.search(rf"(?im)^\s*Head:\s*`?{re.escape(head_oid)}`?\s*$", body):
            continue
        if re.search(r"(?im)^\s*Result:\s*passed\s*$", body):
            return True
    return False


def deployed_validation_passed_for_head(pr: dict[str, Any]) -> bool:
    if DEPLOYED_VALIDATION_PASSED_LABEL not in common.label_names(pr):
        return False
    head_oid = str(pr.get("headRefOid") or "").strip()
    if not head_oid:
        return False
    for comment in reversed(pr.get("comments") or []):
        body = str(comment.get("body") or "")
        if DEPLOYED_VALIDATION_COMMENT_MARKER not in body:
            continue
        if not re.search(rf"(?im)^\s*Head:\s*`?{re.escape(head_oid)}`?\s*$", body):
            continue
        if re.search(r"(?im)^\s*Result:\s*passed\s*$", body):
            return True
    return False


def semantic_review_state_for_head(pr: dict[str, Any]) -> str:
    head_oid = str(pr.get("headRefOid") or "").strip()
    if not head_oid:
        return "missing"
    for comment in reversed(pr.get("comments") or []):
        body = str(comment.get("body") or "")
        if SEMANTIC_REVIEW_COMMENT_MARKER not in body:
            continue
        if not re.search(rf"(?im)^\s*Head:\s*`?{re.escape(head_oid)}`?\s*$", body):
            continue
        if re.search(r"(?im)^\s*Result:\s*(pass|passed)\s*$", body):
            return "passed"
        if re.search(r"(?im)^\s*Result:\s*(fail|failed)\s*$", body):
            return "failed"
        if re.search(r"(?im)^\s*Result:\s*(needs-human|needs_human|blocked)\s*$", body):
            return "needs-human"
    return "missing"


def semantic_review_body_for_head(pr: dict[str, Any]) -> str:
    head_oid = str(pr.get("headRefOid") or "").strip()
    if not head_oid:
        return ""
    for comment in reversed(pr.get("comments") or []):
        body = str(comment.get("body") or "")
        if SEMANTIC_REVIEW_COMMENT_MARKER not in body:
            continue
        if not re.search(rf"(?im)^\s*Head:\s*`?{re.escape(head_oid)}`?\s*$", body):
            continue
        return body
    return ""


def semantic_failure_reasons_for_head(pr: dict[str, Any]) -> list[str]:
    body = semantic_review_body_for_head(pr).lower()
    if not body:
        return ["semantic review failed for current head"]
    reasons: list[str] = []
    explicit_cross_repo = (
        "this pr must modify" in body
        or "this pr needs to modify" in body
        or "same pr must modify" in body
        or "requires changes in another repo in this pr" in body
    )
    if explicit_cross_repo:
        reasons.append("semantic review failed: cross-repo scope gap")
    if any(token in body for token in ("deployed validation", "hosted walkthrough", "apim", "manual/deployed validation")):
        reasons.append("semantic review failed: deployed validation evidence missing")
    if any(token in body for token in ("missing test", "tests do not cover", "insufficient test", "coverage")):
        reasons.append("semantic review failed: test coverage missing")
    if not reasons:
        reasons.append("semantic review failed for current head")
    return reasons


def issue_has_manual_validation(issue: dict[str, Any] | None) -> bool:
    if not issue:
        return False
    body = str(issue.get("body") or "")
    lowered = body.lower()
    labels = common.label_names(issue)
    return bool(
        common.has_nonempty_body_field(body, "Manual gates remaining")
        or "needs-deployed-validation" in labels
        or "needs-deployed-validation" in lowered
        or "validation scope: `deployed`" in lowered
        or "validation scope: deployed" in lowered
        or "manual-validation-required" in labels
    )


def manual_validation_approved(pr: dict[str, Any], issue: dict[str, Any] | None) -> bool:
    labels = common.label_names(pr)
    if issue:
        labels |= common.label_names(issue)
    if DEPLOYED_VALIDATION_PASSED_LABEL in labels:
        return deployed_validation_passed_for_head(pr)
    return MANUAL_APPROVED_LABEL in labels


def review_changes_requested(pr: dict[str, Any]) -> bool:
    decision = str(pr.get("reviewDecision") or "").upper()
    if decision == "CHANGES_REQUESTED":
        return True
    for review in pr.get("latestReviews") or []:
        state = str(review.get("state") or "").upper()
        if state in {"CHANGES_REQUESTED", "REQUEST_CHANGES"}:
            return True
    return False


def blocker_types_for(label: str, reasons: list[str]) -> list[str]:
    if label == APPROVED_LABEL:
        return []
    types: set[str] = set()
    reason_text = " ".join(reasons).lower()
    if label == LOCAL_VALIDATION_REQUIRED_LABEL or "local validation required" in reason_text:
        types.add("local_validation")
    if label == MANUAL_LABEL or "manual or deployed validation required" in reason_text:
        types.add("deployed_validation")
    if label == SEMANTIC_REVIEW_REQUIRED_LABEL or "semantic review required" in reason_text or "semantic review needs human" in reason_text:
        types.add("semantic_review")
    if "semantic review failed for current head" in reason_text:
        types.add("semantic_scope_repair")
    if "semantic review failed: cross-repo scope gap" in reason_text:
        types.add("cross_repo_scope")
    if "semantic review failed: deployed validation evidence missing" in reason_text:
        types.add("deployed_validation")
    if "semantic review failed: test coverage missing" in reason_text:
        types.add("code_repair")
    if "review changes requested" in reason_text:
        types.add("requested_changes")
    if "checks failed:" in reason_text and "failed workflow classified:" not in reason_text:
        types.add("code_repair")
    if "failed workflow classified: code-repair" in reason_text:
        types.add("code_repair")
    if "failed workflow classified: test-repair" in reason_text:
        types.add("code_repair")
    if "failed workflow classified: infra/env" in reason_text:
        types.add("infra_env")
    if "failed workflow classified: secret/config" in reason_text:
        types.add("secret_config")
    if "failed workflow classified: deployed-validation" in reason_text:
        types.add("deployed_validation")
    if "failed workflow classified: human-action" in reason_text:
        types.add("human_action")
    if "failed workflow classified: dependency-blocked" in reason_text:
        types.add("dependency_blocker")
    if "ci review required" in reason_text:
        types.add("ci_review")
    if label == CHECKS_PENDING_LABEL or "checks pending:" in reason_text:
        types.add("check_wait")
    if "merge state is" in reason_text or "mergeable is" in reason_text:
        types.add("merge_repair")
    if "missing linked issue" in reason_text or "could not be verified" in reason_text:
        types.add("metadata_blocker")
    if "dependency blocked:" in reason_text:
        types.add("dependency_blocker")
    if label == OVERLAP_LABEL or "queued behind overlapping pr" in reason_text or "overlaps open local-agent prs" in reason_text:
        types.add("overlap_wait")
    if label == SUPERSEDED_LABEL:
        types.add("superseded")
    if not types:
        types.add("human_decision")
    return sorted(types)


def repair_scope_for(blocker_types: list[str]) -> str:
    blockers = set(blocker_types)
    if "cross_repo_scope" in blockers:
        return "cross-repo"
    if blockers & {"dependency_blocker", "metadata_blocker", "secret_config", "infra_env"}:
        return "metadata"
    if blockers & {"deployed_validation", "local_validation"} and not blockers & CURRENT_REPO_REPAIR_TYPES:
        return "validation"
    if blockers & {"overlap_wait", "check_wait", "semantic_review", "superseded", "ci_review"}:
        return "state"
    if blockers & CURRENT_REPO_REPAIR_TYPES:
        return "current-repo"
    return "human"


def repairable_for(blocker_types: list[str]) -> bool:
    blockers = set(blocker_types)
    return "cross_repo_scope" not in blockers and bool(blockers & CURRENT_REPO_REPAIR_TYPES) and repair_scope_for(blocker_types) == "current-repo"


def route_for(label: str, reasons: list[str]) -> str:
    blocker_types = blocker_types_for(label, reasons)
    if label == APPROVED_LABEL:
        return "approved"
    if label == HUMAN_ACTION_LABEL:
        return "human"
    if label == LOCAL_VALIDATION_REQUIRED_LABEL:
        return "local-validate"
    if label == MANUAL_LABEL:
        return "deployed-validate"
    if label == SEMANTIC_REVIEW_REQUIRED_LABEL:
        return "semantic-review"
    if label == CHECKS_PENDING_LABEL:
        return "wait"
    if label == OVERLAP_LABEL:
        return "wait"
    if label == SUPERSEDED_LABEL:
        return "terminal"
    if repairable_for(blocker_types):
        return "repair"
    if "cross_repo_scope" in blocker_types:
        return "human"
    if "human_action" in blocker_types or "secret_config" in blocker_types or "infra_env" in blocker_types:
        return "human"
    if "ci_review" in blocker_types:
        return "needs-ci-review"
    if "deployed_validation" in blocker_types:
        return "deployed-validate"
    if "local_validation" in blocker_types:
        return "local-validate"
    if "check_wait" in blocker_types:
        return "wait"
    return "human"


def route_for_decision(decision: ReviewDecision) -> str:
    return route_for(decision.label, decision.reasons)


def policy_decision_for(decision: ReviewDecision) -> str:
    route = route_for_decision(decision)
    if route == "approved":
        return "approved"
    if route in {"repair"}:
        return "needs-repair"
    if route in {"deployed-validate"}:
        return "deployed-validate"
    if route in {"wait", "terminal"}:
        return "wait"
    if route in {"needs-ci-review", "local-validate", "semantic-review"}:
        return "needs-ci-review"
    return "human"


def has_superseded_signal(pr: dict[str, Any], issue: dict[str, Any] | None) -> bool:
    labels = common.label_names(pr) | (common.label_names(issue) if issue else set())
    if "agent:superseded" in labels:
        return True

    titles = " ".join(
        [
            str(pr.get("title") or ""),
            str(issue.get("title") or "") if issue else "",
        ]
    ).lower()
    if any(marker in titles for marker in ("superseded", "stale duplicate", "stale/superseded")):
        return True

    explicit_markers = re.compile(
        r"^(?:[-*]\s*)?(?:"
        r"agent:superseded|"
        r"stale duplicate\b|"
        r"stale/superseded\b|"
        r"superseded(?:\s+by\b|:|\s*$)|"
        r"(?:automation\s+)?status:\s*superseded\b"
        r")",
        re.I,
    )
    bodies = [str(pr.get("body") or "")]
    if issue:
        bodies.append(str(issue.get("body") or ""))
    return any(explicit_markers.search(line.strip()) for body in bodies for line in body.splitlines())


def overlapping_prs(
    repo: str,
    number: int,
    files: list[str],
    open_details: list[tuple[dict[str, Any], list[str]]],
) -> list[int]:
    own = set(files)
    if not own:
        return []
    overlaps: list[int] = []
    for other, other_files in open_details:
        other_number = int(other.get("number") or 0)
        if other_number == number or not is_local_agent_pr(other):
            continue
        if own & set(other_files):
            overlaps.append(other_number)
    return sorted(overlaps)


def overlap_map(open_details: list[tuple[dict[str, Any], list[str]]]) -> dict[int, set[int]]:
    result: dict[int, set[int]] = {}
    for detail, files in open_details:
        number = int(detail.get("number") or 0)
        if not number or not is_local_agent_pr(detail):
            continue
        result.setdefault(number, set())
        own = set(files)
        if not own:
            continue
        for other, other_files in open_details:
            other_number = int(other.get("number") or 0)
            if other_number == number or not is_local_agent_pr(other):
                continue
            if own & set(other_files):
                result[number].add(other_number)
    return result


def overlap_components(overlaps: dict[int, set[int]]) -> list[set[int]]:
    seen: set[int] = set()
    components: list[set[int]] = []
    for number in sorted(overlaps):
        if number in seen:
            continue
        stack = [number]
        component: set[int] = set()
        while stack:
            current = stack.pop()
            if current in component:
                continue
            component.add(current)
            stack.extend(sorted(overlaps.get(current, set()) - component))
        seen.update(component)
        if len(component) > 1:
            components.append(component)
    return components


def apply_overlap_frontier(
    decisions: list[ReviewDecision],
    open_details: list[tuple[dict[str, Any], list[str]]],
) -> None:
    by_number = {decision.number: decision for decision in decisions}
    overlaps = overlap_map(open_details)
    for component in overlap_components(overlaps):
        candidates = [
            by_number[number]
            for number in sorted(component)
            if number in by_number and by_number[number].label in {APPROVED_LABEL, MANUAL_LABEL}
        ]
        if len(candidates) < 2:
            continue
        front = candidates[0]
        for decision in candidates[1:]:
            decision.label = OVERLAP_LABEL
            decision.reasons.append(f"queued behind overlapping PR #{front.number}")


def classify(
    repo: str,
    pr: dict[str, Any],
    *,
    issue: dict[str, Any] | None,
    files: list[str],
    duplicate_issue: bool = False,
    overlap_numbers: list[int] | None = None,
    required_checks: list[str] | None = None,
    required_checks_file: str | None = None,
    check_dependencies: bool = True,
    allow_no_checks: bool = False,
    require_semantic_review: bool = False,
    ci_review: dict[str, Any] | None = None,
) -> ReviewDecision:
    reasons: list[str] = []
    issue_ref = linked_issue_ref(repo, pr)
    issue_repo = issue_ref[0] if issue_ref else None
    issue_number = issue_ref[1] if issue_ref else None
    label = APPROVED_LABEL
    labels = common.label_names(pr)
    manual_validation = issue_has_manual_validation(issue)
    manual_approved = manual_validation_approved(pr, issue)
    if not issue_number:
        label = NEEDS_REPAIR_LABEL
        reasons.append("missing linked issue")
    elif issue is None:
        label = NEEDS_REPAIR_LABEL
        reasons.append(f"linked issue #{issue_number} could not be verified")
    if str(pr.get("state") or "") != "OPEN":
        label = NEEDS_REPAIR_LABEL
        reasons.append(f"state is {pr.get('state')}")
    is_draft = bool(pr.get("isDraft"))
    merge_state = str(pr.get("mergeStateStatus") or "")
    if merge_state and merge_state not in {"CLEAN", "HAS_HOOKS", "UNKNOWN"} and not (is_draft and merge_state == "BLOCKED"):
        label = NEEDS_REPAIR_LABEL
        reasons.append(f"merge state is {merge_state}")
    mergeable = str(pr.get("mergeable") or "")
    if mergeable and mergeable not in {"MERGEABLE", "UNKNOWN"}:
        label = NEEDS_REPAIR_LABEL
        reasons.append(f"mergeable is {mergeable}")
    check_state, check_details = check_rollup_state(repo, pr, required_checks)
    if check_state == "none":
        if manual_validation:
            if manual_approved:
                reasons.append("manual or deployed validation approved with no GitHub checks")
            else:
                label = MANUAL_LABEL
                reasons.append("manual or deployed validation required")
        elif no_checks_expected_for_paths(repo, labels, files, required_checks_file)[0]:
            reasons.append("no checks expected by path policy")
        elif required_checks:
            label = LOCAL_VALIDATION_REQUIRED_LABEL
            reasons.append("no GitHub checks reported; required checks missing")
        elif local_validation_passed_for_head(pr):
            reasons.append("local validation passed with no GitHub checks")
        else:
            label = LOCAL_VALIDATION_REQUIRED_LABEL
            if LOCAL_VALIDATION_PASSED_LABEL in labels:
                reasons.append("local validation pass missing for current head")
            else:
                reasons.append("no checks reported; local validation required")
    elif check_state == "failed":
        label = NEEDS_REPAIR_LABEL
        reasons.append(f"checks {check_state}: {', '.join(check_details[:5])}")
        if ci_review:
            category = str(ci_review.get("category") or "code-repair")
            root_cause = str(ci_review.get("root_cause") or "failed workflow reviewed")
            reasons.append(f"failed workflow classified: {category}: {root_cause}")
            if category in NON_REPAIRABLE_CI_CATEGORIES:
                if category == "deployed-validation":
                    label = MANUAL_LABEL
                else:
                    label = HUMAN_ACTION_LABEL
        else:
            reasons.append("ci review required before repair routing")
    elif check_state == "pending":
        label = CHECKS_PENDING_LABEL
        reasons.append(f"checks {check_state}: {', '.join(check_details[:5])}")
    if issue and check_dependencies:
        blockers = common.issue_dependency_blockers(issue_repo or repo, issue)
        if blockers:
            label = NEEDS_REPAIR_LABEL
            reasons.extend(f"dependency blocked: {blocker}" for blocker in blockers)
    if review_changes_requested(pr):
        label = NEEDS_REPAIR_LABEL
        reasons.append("review changes requested")
    superseded = has_superseded_signal(pr, issue) or duplicate_issue
    if superseded:
        label = SUPERSEDED_LABEL
        if duplicate_issue:
            reasons.append("duplicate linked issue PR")
        else:
            reasons.append("superseded/stale signal")
    overlaps = overlap_numbers or []
    if overlaps and label != SUPERSEDED_LABEL:
        label = OVERLAP_LABEL if label in {APPROVED_LABEL, MANUAL_LABEL} else label
        reasons.append("overlaps open local-agent PRs: " + ", ".join(f"#{n}" for n in overlaps))
    if manual_validation and label != SUPERSEDED_LABEL:
        if "manual or deployed validation approved with no GitHub checks" in reasons:
            pass
        elif label == APPROVED_LABEL and manual_approved:
            reasons.append("manual or deployed validation approved")
        elif "manual or deployed validation required" in reasons:
            pass
        elif label == APPROVED_LABEL:
            label = MANUAL_LABEL
            reasons.append("manual or deployed validation required")
        else:
            reasons.append("manual/deployed validation pending after repair")
    if require_semantic_review and label in {APPROVED_LABEL, MANUAL_LABEL}:
        semantic_state = semantic_review_state_for_head(pr)
        if semantic_state == "passed":
            reasons.append("semantic review passed for current head")
        elif semantic_state == "failed":
            label = NEEDS_REPAIR_LABEL
            reasons.extend(semantic_failure_reasons_for_head(pr))
        elif semantic_state == "needs-human" and label == APPROVED_LABEL:
            label = SEMANTIC_REVIEW_REQUIRED_LABEL
            reasons.append("semantic review needs human attention for current head")
        elif semantic_state == "missing" and label == APPROVED_LABEL:
            label = SEMANTIC_REVIEW_REQUIRED_LABEL
            reasons.append("semantic review required for current head")
    if not reasons:
        reasons.append("green checks and no review blockers")
    return ReviewDecision(
        repo=repo,
        number=int(pr["number"]),
        title=str(pr.get("title") or ""),
        url=str(pr.get("url") or ""),
        issue_repo=issue_repo,
        issue_number=issue_number,
        label=label,
        reasons=reasons,
        files=files,
        ci_review=ci_review,
        current_labels=common.label_names(pr),
    )


def review_comment_body(decision: ReviewDecision) -> str:
    files = "\n".join(f"- `{path}`" for path in decision.files[:20]) or "- none recorded"
    blocker_types = blocker_types_for(decision.label, decision.reasons)
    reason_text = " ".join(decision.reasons).lower()
    next_action = "No action required before finalizer review." if decision.label == APPROVED_LABEL else "Clear the reasons above, add validation evidence if missing, then rerun review."
    if decision.label == MANUAL_LABEL:
        if "local validation passed" in reason_text:
            next_action = (
                f"Local validation is current for this head. Remaining gate is deployed/manual validation: "
                f"run `./atlas-agent-deployed-validate {decision.repo}#{decision.number} --apply` if configured, "
                "or run the named deployed gates from the issue, comment the evidence, then add `agent:manual-validation-approved`."
            )
        else:
            next_action = (
                f"Run configured validation for this PR head. Start with local validation if GitHub checks are absent: "
                f"`./atlas-agent-local-validate {decision.repo}#{decision.number} --apply`; then run deployed/manual gates "
                "or configure `deployed-validation.json`, comment current-head evidence, and add `agent:manual-validation-approved`."
            )
    elif decision.label == LOCAL_VALIDATION_REQUIRED_LABEL:
        next_action = "Run configured local validation for this PR head; review will require current-head `agent:local-validation-passed` evidence."
    elif decision.label == OVERLAP_LABEL:
        next_action = "Wait for the earlier overlapping PR named in the reasons to merge or close, then rerun review."
    elif decision.label == SEMANTIC_REVIEW_REQUIRED_LABEL:
        next_action = "Run `atlas-agent-semantic-review OWNER/REPO#PR --apply`, address any findings, then rerun review."
    elif route_for_decision(decision) == "needs-ci-review":
        next_action = f"Run `./atlas-agent-review --apply` so failed workflows are reviewed on the PR before repair routing."
    elif route_for_decision(decision) == "human":
        next_action = "Follow the blocker-specific instruction in the failed-workflow review, issue, or PR comments, then rerun review."
    return (
        "<!-- atlas-agent-review -->\n"
        f"## Automated Review Decision\n\n"
        f"Classification: `{decision.label}`\n\n"
        f"Decision: `{policy_decision_for(decision)}`\n"
        f"Route: `{route_for_decision(decision)}`\n"
        f"Repair scope: `{repair_scope_for(blocker_types)}`\n\n"
        "Reasons:\n"
        + "\n".join(f"- {reason}" for reason in decision.reasons)
        + "\n\nChanged files reviewed:\n"
        + files
        + "\n\nRequired next action:\n"
        + f"- {next_action}\n\n"
        "Review gate:\n"
        "- Finalization requires `agent:review-approved`.\n"
        "- Approval requires current validation evidence from GitHub checks, local validation, or an explicit manual/deployed validation approval.\n"
    )


def post_review_comment(decision: ReviewDecision) -> None:
    body = review_comment_body(decision)
    comments = common.gh_json_or_none(
        ["api", f"repos/{decision.repo}/issues/{decision.number}/comments"],
        retries=2,
    ) or []
    for comment in comments:
        if "<!-- atlas-agent-review -->" not in str(comment.get("body") or ""):
            continue
        comment_id = str(comment.get("id") or "")
        if not comment_id:
            return
        common.run(
            [
                "gh",
                "api",
                f"repos/{decision.repo}/issues/comments/{comment_id}",
                "-X",
                "PATCH",
                "-f",
                f"body={body}",
            ],
            check=False,
        )
        return
    common.run(["gh", "pr", "comment", str(decision.number), "--repo", decision.repo, "--body", body], check=False)


_LABELS_READY: set[str] = set()


def ensure_review_labels(repo: str) -> None:
    common.ensure_labels_cached(repo, {**REVIEW_LABELS, **REVIEW_AUX_LABELS})


def apply_decision(decision: ReviewDecision, *, comment: bool) -> None:
    ensure_review_labels(decision.repo)
    current_labels = decision.current_labels or set()
    for label in REVIEW_LABELS:
        if label != decision.label and label in current_labels:
            common.run(["gh", "issue", "edit", str(decision.number), "--repo", decision.repo, "--remove-label", label], check=False)
    if decision.label not in current_labels:
        common.run(
            ["gh", "issue", "edit", str(decision.number), "--repo", decision.repo, "--add-label", decision.label],
            retries=3,
        )
    if comment:
        post_review_comment(decision)


def scan(args: argparse.Namespace) -> list[ReviewDecision]:
    decisions: list[ReviewDecision] = []
    allowed_issue_keys = project_issue_keys(getattr(args, "projects_file", None), getattr(args, "project_snapshot", None))
    for repo in target_repos(args.repos_file):
        repo_decisions: list[ReviewDecision] = []
        summaries = [pr for pr in open_prs(repo, args.limit) if is_local_agent_pr(pr)]
        details: list[tuple[dict[str, Any], list[str]]] = []
        for summary in summaries:
            detail = pr_view(repo, int(summary["number"]))
            if not detail:
                continue
            issue_ref = linked_issue_ref(repo, detail)
            if allowed_issue_keys is not None and (
                issue_ref is None or issue_ref not in allowed_issue_keys
            ):
                continue
            files = pr_files(repo, int(summary["number"])) if args.detect_overlap else []
            details.append((detail, files))
        issue_counts: dict[tuple[str, int], int] = {}
        for detail, _files in details:
            issue_ref = linked_issue_ref(repo, detail)
            if issue_ref is not None:
                issue_counts[issue_ref] = issue_counts.get(issue_ref, 0) + 1
        for detail, files in details:
            issue_ref = linked_issue_ref(repo, detail)
            issue_repo = issue_ref[0] if issue_ref else repo
            issue_number = issue_ref[1] if issue_ref else None
            issue = issue_view(issue_repo, issue_number) if issue_number is not None else None
            ci_review = None
            if args.review_failed_workflows and failed_check_summaries(detail):
                job_dir = common.jobs_dir() / f"pr-{int(detail['number'])}-failed-workflow-review-{common.now_id()}"
                job_dir.mkdir(parents=True, exist_ok=True)
                ci_review = fetch_failed_workflow_review(repo, detail, job_dir)
                if ci_review and args.apply and args.comment:
                    post_failed_workflow_review(repo, int(detail["number"]), ci_review)
            repo_decisions.append(
                classify(
                    repo,
                    detail,
                    issue=issue,
                    files=files,
                    duplicate_issue=bool(issue_ref is not None and issue_counts.get(issue_ref, 0) > 1),
                    required_checks=common.required_checks_for_repo(repo, Path(args.required_checks_file) if args.required_checks_file else None),
                    required_checks_file=args.required_checks_file,
                    check_dependencies=args.check_dependencies,
                    allow_no_checks=args.allow_no_checks,
                    require_semantic_review=args.require_semantic_review,
                    ci_review=ci_review,
                )
            )
        if args.detect_overlap:
            apply_overlap_frontier(repo_decisions, details)
        decisions.extend(repo_decisions)
    return decisions


def write_summary(path: str, decisions: list[ReviewDecision]) -> None:
    common.write_json(
        Path(path),
        {
            "generated_at": common.now_id(),
            "decisions": [
                {
                    "repo": decision.repo,
                    "number": decision.number,
                    "title": decision.title,
                    "url": decision.url,
                    "issue_repo": decision.issue_repo,
                    "issue_number": decision.issue_number,
                    "label": decision.label,
                    "route": route_for_decision(decision),
                    "blocker_types": blocker_types_for(decision.label, decision.reasons),
                    "repair_scope": repair_scope_for(blocker_types_for(decision.label, decision.reasons)),
                    "repairable": repairable_for(blocker_types_for(decision.label, decision.reasons)),
                    "decision": policy_decision_for(decision),
                    "reasons": decision.reasons,
                    "files": decision.files,
                    "ci_review": decision.ci_review,
                }
                for decision in decisions
            ],
        },
    )


def main() -> None:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--repos-file")
    parser.add_argument("--limit", type=int, default=50)
    parser.add_argument("--required-checks-file")
    parser.add_argument("--allow-no-checks", action="store_true")
    parser.add_argument("--check-dependencies", action=argparse.BooleanOptionalAction, default=True)
    parser.add_argument("--detect-overlap", action=argparse.BooleanOptionalAction, default=True)
    parser.add_argument("--require-semantic-review", action=argparse.BooleanOptionalAction, default=True)
    parser.add_argument(
        "--review-failed-workflows",
        action=argparse.BooleanOptionalAction,
        default=True,
        help="Fetch failed workflow runs/jobs/log excerpts and post/update a concise failed-workflow review when applying.",
    )
    parser.add_argument("--apply", action="store_true")
    parser.add_argument("--comment", action=argparse.BooleanOptionalAction, default=True)
    parser.add_argument("--projects-file", help="Only review PRs linked to issues in these GitHub Projects.")
    parser.add_argument("--project-snapshot", help="Saved gh project item-list JSON used with --projects-file filtering.")
    parser.add_argument("--summary", help="Write structured review decisions to this JSON path.")
    args = parser.parse_args()

    decisions = scan(args)
    if args.summary:
        write_summary(args.summary, decisions)
    for decision in decisions:
        print(
            f"{'APPLY' if args.apply else 'DRY-RUN'} REVIEW "
            f"{decision.repo}#{decision.number}: {decision.label}: {', '.join(decision.reasons)}",
            flush=True,
        )
        if args.apply:
            apply_decision(decision, comment=args.comment)


if __name__ == "__main__":
    main()
