{
  "OWNER/REPO": {
    "install_commands": [
      "python3 -m pip install -r requirements-dev.txt"
    ],
    "commands": [
      "python3 -m pytest tests/deployed"
    ],
    "workflows": [
      {
        "workflow": "deployed-validation.yml",
        "ref": "$PR_HEAD_BRANCH",
        "inputs": {
          "dry_run": "true",
          "pr_number": "$PR_NUMBER"
        }
      }
    ],
    "env": {
      "DEPLOYED_VALIDATION_DRY_RUN": "true"
    }
  }
}
