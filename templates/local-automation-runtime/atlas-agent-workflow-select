#!/usr/bin/env python3
"""Inspect Atlas workflow template selection for a work item or request."""

from __future__ import annotations

import argparse
import json
import pathlib
import sys
from typing import Any


RUNTIME_DIR = pathlib.Path(__file__).resolve().parent
if str(RUNTIME_DIR) not in sys.path:
    sys.path.insert(0, str(RUNTIME_DIR))

import atlas_workflows


def read_json(path: str | pathlib.Path) -> Any:
    return json.loads(pathlib.Path(path).read_text(encoding="utf-8"))


def work_item_from_payload(payload: Any, work_item_id: str) -> dict[str, Any]:
    if isinstance(payload, dict) and isinstance(payload.get("work_items"), list):
        if not work_item_id and len(payload["work_items"]) == 1:
            item = payload["work_items"][0]
            return item if isinstance(item, dict) else {}
        for item in payload["work_items"]:
            if isinstance(item, dict) and str(item.get("id") or item.get("source_id") or "") == work_item_id:
                return item
        raise SystemExit(f"work item not found: {work_item_id or '<required>'}")
    if isinstance(payload, dict) and isinstance(payload.get("work_items"), dict):
        items = payload["work_items"]
        if not work_item_id and len(items) == 1:
            item = next(iter(items.values()))
            return item if isinstance(item, dict) else {}
        item = items.get(work_item_id)
        if isinstance(item, dict):
            return item
        raise SystemExit(f"work item not found: {work_item_id or '<required>'}")
    if isinstance(payload, dict):
        return payload
    raise SystemExit("work item JSON must be an object or a store with work_items")


def request_from_args(args: argparse.Namespace) -> dict[str, Any]:
    if args.work_item:
        payload = read_json(args.work_item)
        return atlas_workflows.work_item_workflow_request(work_item_from_payload(payload, args.work_item_id or ""))
    return {
        "workflow_kind": args.workflow_kind or "",
        "team_template": args.team_template or "",
        "required_outputs": args.required_output or [],
    }


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument(
        "--team-templates",
        default=str(RUNTIME_DIR / "team-templates"),
        help="Template JSON file or directory to inspect.",
    )
    parser.add_argument("--work-item", help="Work item JSON object or JSON store containing work_items.")
    parser.add_argument("--work-item-id", help="Work item id to select from a JSON store.")
    parser.add_argument("--workflow-kind", help="Workflow kind to select when --work-item is not provided.")
    parser.add_argument("--team-template", help="Explicit template id to select when --work-item is not provided.")
    parser.add_argument(
        "--required-output",
        action="append",
        default=[],
        help="Required output name; may be provided multiple times.",
    )
    parser.add_argument("--json", action="store_true", help="Print the full selection report as JSON.")
    return parser


def print_text_report(report: dict[str, Any]) -> None:
    request = report["request"]
    print("Workflow template selection")
    print(f"- workflow_kind: {request['workflow_kind'] or '<any>'}")
    print(f"- team_template: {request['team_template'] or '<none>'}")
    print(f"- required_outputs: {', '.join(request['required_outputs']) or '<none>'}")
    selected = report.get("selected_template")
    selection = report.get("selection") or {}
    print(f"- selected_template: {selected or '<none>'}")
    print(f"- selection_status: {selection.get('status') or '<unknown>'}")
    print(f"- suggested_action: {selection.get('suggested_action') or '<unknown>'}")
    if selection.get("closest_template") and selection.get("closest_template") != selected:
        print(f"- closest_template: {selection['closest_template']}")
    if selection.get("uncovered_required_outputs"):
        print(f"- uncovered_required_outputs: {', '.join(selection['uncovered_required_outputs'])}")
    for candidate in report["candidates"]:
        marker = "*" if candidate["id"] == selected else "-"
        missing = ", ".join(candidate["missing_required_outputs"]) or "none"
        print(
            f"{marker} {candidate['id']} ({candidate['workflow_kind']}): "
            f"selectable={str(candidate['selectable']).lower()}, missing={missing}"
        )


def main(argv: list[str] | None = None) -> int:
    args = build_parser().parse_args(argv)
    templates = atlas_workflows.load_team_templates(args.team_templates)
    report = atlas_workflows.template_selection_report(templates, request_from_args(args))
    if args.json:
        print(json.dumps(report, indent=2, sort_keys=True))
    else:
        print_text_report(report)
    return 0 if report.get("selected_template") else 1


if __name__ == "__main__":
    raise SystemExit(main())
