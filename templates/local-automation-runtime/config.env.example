# Copy to config.env and fill local-only values.

AGENT_REPO="OWNER/REPO"
AGENT_BASE_BRANCH="main"
# Optional per-repo base branch override. Replace OWNER_REPO with the uppercased
# repo slug and non-alphanumeric characters converted to underscores.
# AGENT_BASE_BRANCH_OWNER_REPO="main"
AGENT_PROJECT_OWNER="OWNER"
AGENT_PROJECT_NUMBER="1"
AGENT_PROJECT_ITEM_LIMIT="500"
AGENT_PROJECT_RECONCILE_EVERY="0"
AGENT_PROJECT_STATE_UPDATES="false"
# Set to "queue" to append desired Project field updates under jobs/project-sync
# instead of calling gh project from the hot path.
AGENT_PROJECT_STATE_UPDATE_MODE="direct"
AGENT_REQUIRED_CHECKS_FILE="$PWD/required-checks.json"

AGENT_READY_LABEL="agent:ready"
AGENT_RUNNING_LABEL="agent:running"
AGENT_DONE_LABEL="agent:done"
AGENT_PR_OPEN_LABEL="agent:pr-open"
AGENT_FAILED_LABEL="agent:failed"
AGENT_ALLOW_WORKFLOWS_LABEL="agent:allow-workflows"
AGENT_ALLOW_INFRA_LABEL="agent:allow-infra"
AGENT_ALLOW_LARGE_LABEL="agent:allow-large"

AGENT_TRUSTED_AUTHORS="YOUR_GITHUB_LOGIN"
AGENT_GIT_USER_NAME="Local Automation Agent"
AGENT_GIT_USER_EMAIL="local-automation-agent@users.noreply.github.com"

AGENT_HOME="$PWD"
AGENT_REPOS="$PWD/repos"
AGENT_JOBS="$PWD/jobs"
AGENT_LOGS="$PWD/logs"

# Runtime artifact cleanup. The unattended loop runs the cleanup stage by
# default in dry-run mode. Set AGENT_CLEANUP_MODE=apply, or pass
# --cleanup-mode apply, only after reviewing atlas-agent-cleanup output.
AGENT_CLEANUP_MODE="dry-run"
AGENT_CLEANUP_CHECKOUT_MAX_AGE_HOURS="24"
AGENT_CLEANUP_KEEP_CHECKOUTS_PER_REPO="8"
AGENT_CLEANUP_JOB_MAX_AGE_HOURS="168"
AGENT_CLEANUP_KEEP_JOBS="200"
AGENT_CLEANUP_CODEX_HOME_MAX_AGE_HOURS="24"
AGENT_CLEANUP_LOG_MAX_AGE_HOURS="336"
AGENT_CLEANUP_IMPORTED_TEMPLATE_MAX_AGE_HOURS="168"
AGENT_CLEANUP_PROTECT_RECENT_HOURS="2"
AGENT_CLEANUP_ACTIVE_JOB_HOURS="12"
AGENT_CLEANUP_MAX_DELETE="0"

# Codex auth is a provider/subscription boundary. Keep one runtime-local
# codex-home per project/subscription; do not point isolated automation at a
# shared user home such as /home/mat/.codex.
AGENT_CODEX_HOME="$PWD/codex-home"
AGENT_CODEX_ISOLATION_REQUIRED="true"
# Emergency-only override. Leave false unless a human intentionally accepts
# shared Codex home billing/data coupling for a supervised run.
AGENT_ALLOW_SHARED_CODEX_HOME="false"
AGENT_PROVIDER_ACCOUNT_ID=""
AGENT_PROVIDER_ACCOUNT_LABEL=""
AGENT_PROVIDER_SUBSCRIPTION_LABEL=""
# Optional ChatGPT workspace guard. When set, codex-home/config.toml must set
# forced_chatgpt_workspace_id to this exact value.
AGENT_CODEX_WORKSPACE_ID=""
AGENT_REPO_ENV_OVERLAY_DIR="$PWD/repo-env"
ATLAS_TOOLS_ROOT=""

AGENT_MAX_FILES_CHANGED="20"
AGENT_MAX_DIFF_LINES="1200"
AGENT_CODEX_TIMEOUT_SECONDS="1800"

# Runtime-wide GitHub CLI pacing. Keep enabled when running parallel lanes;
# all local runtime processes share this state through AGENT_JOBS.
AGENT_GITHUB_THROTTLE="true"
AGENT_GITHUB_MIN_INTERVAL_SECONDS="0.75"
AGENT_GITHUB_GRAPHQL_INTERVAL_SECONDS="2.0"
AGENT_GITHUB_PROJECT_INTERVAL_SECONDS="5.0"
AGENT_GITHUB_MUTATION_INTERVAL_SECONDS="2.0"
AGENT_GITHUB_RATE_LIMIT_BACKOFF_SECONDS="900"

AGENT_CODEX_IMAGE="localhost/codex-agent:latest"
AGENT_PODMAN_CMD="podman"

# Optional per-stage Codex profiles. Prefer profiles for full model/reasoning
# configuration; use *_MODEL or *_EXTRA_ARGS for small local overrides.
AGENT_CODEX_PLANNING_PROFILE=""
AGENT_CODEX_IMPLEMENTATION_PROFILE=""
AGENT_CODEX_REVIEW_PROFILE=""
AGENT_CODEX_REPAIR_PROFILE=""
AGENT_CODEX_PLANNING_MODEL=""
AGENT_CODEX_IMPLEMENTATION_MODEL=""
AGENT_CODEX_REVIEW_MODEL=""
AGENT_CODEX_REPAIR_MODEL=""
AGENT_CODEX_PLANNING_EXTRA_ARGS=""
AGENT_CODEX_IMPLEMENTATION_EXTRA_ARGS=""
AGENT_CODEX_REVIEW_EXTRA_ARGS=""
AGENT_CODEX_REPAIR_EXTRA_ARGS=""
AGENT_CODEX_PLANNING_TIMEOUT_SECONDS=""
AGENT_CODEX_REVIEW_TIMEOUT_SECONDS=""
AGENT_CODEX_REPAIR_TIMEOUT_SECONDS=""
AGENT_CODEX_WORKSTREAM_REVIEW_TIMEOUT_SECONDS=""
AGENT_CODEX_WORKFLOW_ROLE_PROFILE=""
AGENT_CODEX_WORKFLOW_ROLE_MODEL=""
AGENT_CODEX_WORKFLOW_ROLE_EXTRA_ARGS=""
AGENT_CODEX_WORKFLOW_ROLE_TIMEOUT_SECONDS="900"
# Leave false until a human explicitly approves Codex execution for workflow roles.
ATLAS_ROLE_CODEX_ALLOW_EXECUTE="false"

TEAMS_ISSUES_WEBHOOK_URL=""
TEAMS_URGENT_WEBHOOK_URL=""
TEAMS_DAILY_DIGEST_WEBHOOK_URL=""
TEAMS_WEBHOOK_URL=""
